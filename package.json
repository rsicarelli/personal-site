{
  "name": "personal-site",
  "version": "0.0.0",
  "private": true,
  "description": "Source for rsicarelli.com — bilingual (pt-BR / English) personal site & content hub.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check --minimumSeverity warning",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:i18n": "node scripts/check-locale-completeness.mjs",
    "ingest:devto": "node scripts/ingest-devto.mjs && prettier --write 'src/content/blog/**/*.md' 'src/content/series/**/*.yaml'",
    "seed:reactions": "node scripts/seed-reactions.mjs",
    "test": "vitest run",
    "test:i18n": "vitest run tests/i18n",
    "test:seo": "vitest run tests/seo",
    "test:watch": "vitest",
    "lighthouse": "lhci autorun",
    "lighthouse:prod": "lhci autorun --config=lighthouserc.prod.json",
    "deploy": "wrangler pages deploy dist --project-name personal-site"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "mdast-util-to-string": "^4.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.3.0",
    "astro-pagefind": "^2.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "linkedom": "^0.18.12",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
