#!/usr/bin/env bash
# rsicarelli.com — pre-commit hook
#
# Runs the Definition of Done gate (Astro/TS typecheck + ESLint + Prettier check), with
# formatting treated as a read-only check so an unformatted commit is rejected with a clear
# hint instead of silently rewriting the working tree mid-commit.
#
# Enable: task hooks:install     (sets core.hooksPath to .githooks)
# Skip once: git commit --no-verify
set -euo pipefail

if ! command -v task >/dev/null 2>&1; then
  echo "pre-commit: 'task' is not installed (see .tool-versions / 'mise install'). Skipping DOD checks." >&2
  exit 0
fi

echo "→ format check"
if ! task fmt:check >/dev/null 2>&1; then
  echo "" >&2
  echo "✗ Files are not formatted." >&2
  echo "  Run: task fmt && git add -u" >&2
  exit 1
fi

echo "→ typecheck"
task typecheck >/dev/null

echo "→ lint"
task lint >/dev/null

echo "✓ DOD checks passed"
