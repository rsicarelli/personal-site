# Runtime configuration — copy to `.env` and fill in. NEVER commit a real `.env`
# (it is gitignored; only this example is tracked). Values are validated by the
# astro:env schema in astro.config.mjs.
#
# Convention:
#   - PUBLIC_*  → exposed to the client (safe to ship in the built HTML/JS).
#   - secrets   → server-only; add them as server/secret fields in the env schema, never here.

# Canonical site origin (used for canonical URLs + sitemap). Defaults to https://rsicarelli.com.
PUBLIC_SITE_URL=https://rsicarelli.com

# Umami analytics (cookieless) — wired up in the Analytics epic (#71). Leave blank locally.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=

# Base URL for photos/downloads (#36/#37). Defaults to the local `public/media/` dir, so leave it
# blank locally. Set it to the Cloudflare R2 public base in the Hosting epic (#67). Media binaries
# never live in git.
PUBLIC_MEDIA_BASE_URL=
