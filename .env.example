# Runtime configuration — copy to `.env` and fill in. NEVER commit a real `.env`
# (it is gitignored; only this example is tracked). Values are validated by the
# astro:env schema in astro.config.mjs.
#
# Convention:
#   - PUBLIC_*  → exposed to the client (safe to ship in the built HTML/JS).
#   - secrets   → server-only; add them as server/secret fields in the env schema, never here.

# Canonical site origin (used for canonical URLs + sitemap). Defaults to https://rsicarelli.com.
PUBLIC_SITE_URL=https://rsicarelli.com

# Umami analytics (cookieless) — wired up in the Analytics epic (#71). Leave blank locally.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=

# Giscus comments (#195) — GitHub Discussions backend, cookieless. Leave blank locally; set all four
# in the Cloudflare Pages project env vars (Production + Preview) once you've enabled Discussions and
# installed the Giscus app. Get the repo/category IDs from https://giscus.app. See docs/comments.md.
#   PUBLIC_GISCUS_REPO=rsicarelli/personal-site
#   PUBLIC_GISCUS_REPO_ID=R_xxxxxxxx
#   PUBLIC_GISCUS_CATEGORY=Comments
#   PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxx
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# Newsletter (#197) — Buttondown, double opt-in. Leave blank locally. In production set
# PUBLIC_NEWSLETTER_ENABLED=true (gates the footer form) AND add BUTTONDOWN_API_KEY as a *Secret* in
# the Cloudflare Pages dashboard (Production + Preview) — it is read server-side by the
# /api/subscribe function, NOT here. See docs/newsletter.md.
PUBLIC_NEWSLETTER_ENABLED=

# Base URL for photos/downloads (#36/#37). Defaults to the local `public/media/` dir, so leave it
# blank locally. In production it points at the Cloudflare R2 public bucket over its custom domain;
# set this value in the Cloudflare Pages project env vars (Production + Preview), NOT here, e.g.:
#   PUBLIC_MEDIA_BASE_URL=https://media.rsicarelli.com
# Upload assets with scripts/upload-media.sh. Media binaries never live in git.
PUBLIC_MEDIA_BASE_URL=
