{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm preview --port 4321",
      "startServerReadyPattern": "localhost:4321",
      "url": [
        "http://localhost:4321/en/",
        "http://localhost:4321/pt-br/",
        "http://localhost:4321/en/about/",
        "http://localhost:4321/en/blog/kotlin-multiplatform-in-production/",
        "http://localhost:4321/en/blog/kmp-102-utilizando-codigo-kotlin-no-swift/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new",
        "skipAudits": ["robots-txt"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
