# Cloudflare Pages response headers.
#
# Two concerns live here:
#   1. Caching for the content-hashed /_astro/* assets (immutable, cache-forever).
#   2. Security headers for the whole site (#77) — applied to every response via /*.
#
# CSP NOTE — ENFORCED. A static Cloudflare Pages site can't use per-request nonces, so the
# Content-Security-Policy allow-lists every inline <script> the build emits by its sha256 hash. The
# site emits several inline scripts (verified by the build): authored is:inline scripts (theme
# bootstrap, locale gateway), the env-gated Umami tracker and Giscus loader, two Astro framework
# runtimes (ClientRouter + island hydration), and component scripts (LiteYouTube facade, About print
# button, ShareButtons enhancement). The
# framework/component hashes are derived from MINIFIED output, so they change on an Astro upgrade or a
# component edit. `tests/security/csp-hashes.test.ts` rebuilds and fails CI if any emitted inline
# script is missing from the list below, printing the new hash to paste — that guard is what keeps
# this maintainable.
#
# The policy is ENFORCED (#199 security audit): `script-src` is hash/allowlist-based with NO
# 'unsafe-inline', so an injected <script> is BLOCKED, not just logged. COOP/COEP are deliberately
# omitted — they would break the Giscus GitHub-OAuth popup and the YouTube embed.
#
# Hash map (kept in sync by the guard test):
#   tLArEO3il…  locale gateway redirect      (src/pages/index.astro, is:inline)
#   bKZtodDur…  theme bootstrap (no-FOUC)    (src/layouts/BaseLayout.astro, is:inline)
#   KdU/9Vtkl…  Umami tracker                (src/components/Analytics.astro, is:inline set:html)
#   QzWFZi+FL…  Astro ClientRouter runtime   (View Transitions, framework-generated)
#   SaCkFfPru…  Astro island hydration       (framework-generated)
#   y5GQlNa4Y…  LiteYouTube facade element   (src/components/ui/LiteYouTube.astro)
#   mFPmtNDq4…  About "Save as PDF" button   (src/pages/[locale]/about.astro)
#   73XFRmUPm…  blog ShareButtons enhancement (src/components/content/ShareButtons.astro)
#   mz2mwtwOB…  Giscus comments loader        (src/components/content/Comments.astro, env-gated)
#   17xXwN1/j…  blog ViewBeacon (#200)        (src/components/content/ViewBeacon.astro)
#   dVYBrUcw/b…  NewsletterSignup (#197)       (src/components/content/NewsletterSignup.astro)
#   O1Ftvr89V…  blog Reactions (#201)          (src/components/content/Reactions.astro)
#   wWrdOb5KG…  blog TableOfContents highlight (src/components/content/TableOfContents.astro)
#   huS3r/iH…  blog EngagementBeacon (#224)    (src/components/content/EngagementBeacon.astro)
#
# Giscus (#195) also needs https://giscus.app in script-src (client.js), connect-src (its API) and
# frame-src (the comments iframe). Avatars/CSS load INSIDE that iframe (giscus.app origin), so they
# fall under Giscus's own CSP, not ours.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(self "https://www.youtube-nocookie.com"), autoplay=(self "https://www.youtube-nocookie.com"), camera=(), clipboard-write=(self "https://www.youtube-nocookie.com"), encrypted-media=(self "https://www.youtube-nocookie.com"), fullscreen=(self "https://www.youtube-nocookie.com"), geolocation=(), gyroscope=(self "https://www.youtube-nocookie.com"), magnetometer=(), microphone=(), payment=(), picture-in-picture=(self "https://www.youtube-nocookie.com"), usb=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; manifest-src 'self'; script-src 'self' 'sha256-tLArEO3il+rQQA6m2oGqMMwslYj7DpbNi4F8hGi3pOc=' 'sha256-bKZtodDurghgGxhmCir/FPF0BELZeXGa5RxormtoLKI=' 'sha256-KdU/9VtklhpD14QEAiNghfaaLeQ08xEjCHOEUBohptM=' 'sha256-QzWFZi+FLIx23tnm9SBU4aEgx4x8DsuASP07mfqol/c=' 'sha256-SaCkFfPruIdTXT8/97JArQmGxiJAL2o4bBDvSgJ5y3Q=' 'sha256-y5GQlNa4YKcA3WBs1ZaXPZ6LhU9RqOOWI4hFL1cqVeA=' 'sha256-mFPmtNDq4l0J5X2QWryz12UQmgxENmZmrqudAYyOfck=' 'sha256-HP1EBS4D0p+BgQskhgADyLdxXITOTVAn88g49DUo4zM=' 'sha256-73XFRmUPm37HISL9YR0rbbroaKCmCJLOJrv8bJXEJqE=' 'sha256-mz2mwtwOBlq94w20jJbIIpF1go0qw65/ToFDyr189Do=' 'sha256-17xXwN1/j+PF6QIyyJgMRpsyKJCshIgxquOFA9IVP3k=' 'sha256-dVYBrUcw/brlojfd1/3WFDcqrmyUgCNwPKEMlZ0jbQQ=' 'sha256-O1Ftvr89VcnnTyaAmEj8NF77GS+hdbWoUahkC9Ekp8c=' 'sha256-wWrdOb5KGxOg63p9w9f+FGErzJh0Lk7PT6ZWELPq/fU=' 'sha256-huS3r/iHrDRvqBsT+Vy8uRjuDtaNrZAmkmA12evC/1c=' https://cloud.umami.is https://giscus.app; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.ytimg.com https://media2.dev.to https://dev-to-uploads.s3.amazonaws.com https://media.rsicarelli.com; font-src 'self'; connect-src 'self' https://cloud.umami.is https://giscus.app; frame-src https://www.youtube-nocookie.com https://giscus.app; upgrade-insecure-requests

# Everything Astro emits under /_astro/* (JS, CSS, optimized images AND the self-hosted fonts
# in /_astro/fonts/) is content-hashed, so the URL changes whenever the bytes change — it is
# safe to cache forever. Cloudflare Pages already sets strong defaults for hashed assets; this
# makes the policy explicit and portable if the host ever changes.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
