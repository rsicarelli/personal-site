---
/**
 * Neutral locale gateway at `/` (#21). Intentionally NOT wrapped in BaseLayout — its Header is
 * locale-bound, and `/` must stay language-neutral. Two things matter for SEO:
 *
 *  1. It is a real, crawlable 200 page with static links to BOTH locales, so Googlebot (which
 *     crawls from US IPs with no Accept-Language) reaches `/en/` and `/pt-br/` from here. There
 *     is NO server redirect — `astro.config.mjs` sets `redirectToDefaultLocale: false`.
 *  2. The only client JS is a tiny inline soft-redirect that sends a visitor to their best-guess
 *     locale. It lives in <head> so it runs BEFORE first paint — JS visitors never see this page
 *     flash; crawlers and no-JS visitors get the styled fallback below with the static links.
 *
 * The gateway advertises both locales + x-default via reciprocal hreflang (#23) so search
 * engines discover the localized roots from `/` itself.
 */
import '../styles/global.css';
import { SITE, DEFAULT_LOCALE } from '@/config/site';
import { buildSeoMeta } from '@/lib/seo';
import { websiteLd, personLd } from '@/lib/jsonld';
import { getLocalizedEntry } from '@/lib/content';
import Cover from '@/components/content/Cover.astro';
import JsonLd from '@/components/content/JsonLd.astro';

const canonical = new URL('/', Astro.site).href;
const alternates = [
  { hreflang: 'en', href: new URL('/en', Astro.site).href },
  { hreflang: 'pt-BR', href: new URL('/pt-br', Astro.site).href },
  { hreflang: 'x-default', href: canonical },
];

// The gateway can't use BaseLayout (its Header is locale-bound), so it calls the SAME OG/Twitter
// builder (#51) directly — no drift with the localized pages. Default locale, website type.
const seoMeta = buildSeoMeta({
  title: SITE.title,
  description: SITE.description,
  canonical,
  locale: DEFAULT_LOCALE,
  image: new URL('/og-default.png', Astro.site).href,
  type: 'website',
  siteName: SITE.title,
});

// Site/author identity for the gateway too (#52) — same WebSite + Person graph as the localized
// home, built from the default-locale CV so `sameAs`/`knowsAbout` stay consistent.
const cv = await getLocalizedEntry('cv', DEFAULT_LOCALE, 'cv');
const siteGraph = [
  websiteLd({ url: canonical, name: SITE.title, locale: DEFAULT_LOCALE }),
  ...(cv
    ? [personLd(cv.entry.data, { url: new URL(`/${DEFAULT_LOCALE}/about`, Astro.site).href })]
    : []),
];

const localeLinks = [
  { href: '/en/', label: 'English', hint: 'Read in English' },
  { href: '/pt-br/', label: 'Português (Brasil)', hint: 'Ler em português' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* Soft, client-only locale detection — parser-blocking in <head> so it runs BEFORE first
        paint (no gateway flash). `location.replace` avoids a back-button trap and is NOT a server
        301/302, so crawlers and the static links below are unaffected. Byte-identical to the CSP
        hash pinned in public/_headers. */
    }
    <script is:inline>
      (function () {
        try {
          const nav = navigator.language || (navigator.languages && navigator.languages[0]) || 'en';
          const target = nav.toLowerCase().indexOf('pt') === 0 ? '/pt-br/' : '/en/';
          location.replace(target);
        } catch {
          /* leave the crawlable gateway in place */
        }
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>rsicarelli.com</title>
    <meta name="description" content={SITE.description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    {seoMeta.map((m) => <meta property={m.property} name={m.name} content={m.content} />)}
    <JsonLd schema={siteGraph} />
  </head>
  <body class="bg-background text-foreground min-h-dvh antialiased">
    <main class="mx-auto flex min-h-dvh max-w-md flex-col justify-center px-6 py-16">
      <div class="border-border bg-card overflow-hidden rounded-lg border">
        <Cover seed="rsicarelli.com" bare class="border-border h-24 w-full border-b" />
        <div class="p-6">
          <p class="text-muted-foreground font-mono text-xs font-semibold tracking-tight">
            rsicarelli.com
          </p>
          <h1 class="mt-2 font-serif text-2xl font-bold tracking-tight">
            Choose your language <span class="text-muted-foreground font-sans font-normal">·</span>
            Escolha seu idioma
          </h1>
          <ul class="mt-6 flex flex-col gap-2">
            {
              localeLinks.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="border-border hover:border-primary/50 hover:bg-secondary/40 group flex items-baseline justify-between gap-4 rounded-md border px-4 py-3 transition-colors"
                  >
                    <span class="group-hover:text-primary font-semibold tracking-tight transition-colors">
                      {l.label}
                    </span>
                    <span class="text-muted-foreground font-mono text-xs">{l.hint} →</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </main>
  </body>
</html>
