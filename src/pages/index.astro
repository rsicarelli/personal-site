---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Button } from '@/components/ui/button';
---

<BaseLayout
  title="rsicarelli.com"
  description="Foundation scaffold for rsicarelli.com — Astro, Tailwind v4, shadcn/ui."
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight">rsicarelli.com</h1>
    <p class="text-muted-foreground mt-3 max-w-prose">
      Foundation scaffold — Astro + Tailwind v4 + shadcn/ui on a themeable Oklch token skeleton.
      Bilingual content, the finalized design system, and real pages land in the i18n, design, and
      content epics.
    </p>

    {
      /* Proving island: a React shadcn/ui component, hydrated on load. The rest of the
        page stays zero-JS — islands hydrate only where interactivity is needed. */
    }
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <Button client:load>Primary</Button>
      <Button variant="outline" client:load>Outline</Button>
      <Button variant="ghost" client:load>Ghost</Button>
    </div>
  </section>
</BaseLayout>
