---
/**
 * Localized About page (#23 demo) â€” one static route per locale (`/en/about`, `/pt-br/about`).
 * Exercises the real URL-locale â†’ content-suffix pipeline: the `pt-br` route loads `about.pt.mdx`
 * and `en` loads `about.en.mdx` via `contentSuffix`. Proves hreflang on a non-home route and the
 * switcher preserving a deep path. Richer page content (Person JSON-LD, CV) lands in #27/#52.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LOCALES, type Locale } from '@/config/site';
import { contentSuffix } from '@/i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  // The glob loader slugifies entry ids (dropping dots: `about.en` â†’ `abouten`), so match on
  // `filePath` â€” the real filename â€” which reliably carries the `.<suffix>.mdx` locale marker.
  return LOCALES.map((locale) => {
    const suffix = contentSuffix(locale);
    const entry = pages.find((p) => p.filePath?.endsWith(`/about.${suffix}.mdx`));
    return { params: { locale }, props: { entry } };
  });
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
if (!entry) throw new Error(`Missing 'about' page entry for locale "${locale}".`);
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight">{entry.data.title}</h1>
    <div class="text-muted-foreground mt-4 max-w-prose space-y-4">
      <Content />
    </div>
  </section>
</BaseLayout>
