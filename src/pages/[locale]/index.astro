---
/**
 * Home hub (#29) — one localized route per locale (`/en/`, `/pt-br/`). Aggregates the content
 * collections through the spine: latest posts, featured projects and upcoming talks, each linking
 * to its section. Sections render only when they have content (draft-filtered in prod). Strings
 * come from the i18n dictionary; cards/layout adopt Epic 5's components as they land.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Card from '@/components/ui/Card.astro';
import RssLinks from '@/components/content/RssLinks.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { LOCALES, SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { websiteLd, personLd } from '@/lib/jsonld';
import { getLocalizedEntries, getLocalizedEntry } from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);

// Site-wide graph (#52): WebSite + the rich Person, so the home page asserts the site/author
// identity. The Person is the same node the About page emits — both built from the shared CV.
const homeUrl = canonicalUrl('/', locale, Astro.site);
const cv = await getLocalizedEntry('cv', locale, 'cv');
const siteGraph = [
  websiteLd({ url: homeUrl, name: SITE.title, locale }),
  ...(cv ? [personLd(cv.entry.data, { url: canonicalUrl('/about', locale, Astro.site) })] : []),
];

const posts = (await getLocalizedEntries('blog', locale)).slice(0, 3);
const projects = (await getLocalizedEntries('portfolio', locale))
  .filter((p) => p.entry.data.featured)
  .slice(0, 3);
const now = new Date();
const upcoming = (await getLocalizedEntries('events', locale))
  .filter((e) => (e.entry.data.endDate ?? e.entry.data.startDate) >= now)
  .sort((a, b) => a.entry.data.startDate.getTime() - b.entry.data.startDate.getTime())
  .slice(0, 2);
---

<BaseLayout title={t('site.title')} description={t('site.description')}>
  <RssLinks slot="head" locale={locale} />
  <JsonLd slot="head" schema={siteGraph} />
  <Container class="py-16">
    <section>
      <h1 class="text-4xl font-bold tracking-tight">{t('home.heading')}</h1>
      <p class="text-muted-foreground mt-4 max-w-prose text-lg">{t('home.intro')}</p>
    </section>

    {
      posts.length > 0 && (
        <section class="mt-16">
          <div class="flex items-baseline justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight">{t('home.latestPosts')}</h2>
            <a
              href={`/${locale}/blog`}
              class="text-muted-foreground hover:text-foreground font-mono text-xs"
            >
              {t('blog.allPosts')} →
            </a>
          </div>
          <ul class="mt-6 space-y-6">
            {posts.map(({ slug, entry }) => (
              <li class="border-border border-b pb-6 last:border-0">
                <h3 class="font-semibold tracking-tight">
                  <a href={`/${locale}/blog/${slug}`} class="hover:text-primary transition-colors">
                    {entry.data.title}
                  </a>
                </h3>
                <p class="text-muted-foreground mt-1 font-mono text-xs">
                  <time datetime={isoDate(entry.data.pubDate)}>
                    {formatDate(entry.data.pubDate, locale, 'medium')}
                  </time>
                </p>
                <p class="text-muted-foreground mt-2 max-w-prose text-sm">
                  {entry.data.description}
                </p>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      projects.length > 0 && (
        <section class="mt-16">
          <div class="flex items-baseline justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight">{t('home.featuredProjects')}</h2>
            <a
              href={`/${locale}/projects`}
              class="text-muted-foreground hover:text-foreground font-mono text-xs"
            >
              {t('projects.allProjects')} →
            </a>
          </div>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            {projects.map(({ slug, entry }) => (
              <Card as="li">
                <h3 class="font-mono font-semibold tracking-tight">
                  <a
                    href={`/${locale}/projects/${slug}`}
                    class="hover:text-primary transition-colors"
                  >
                    {entry.data.title}
                  </a>
                </h3>
                <p class="text-muted-foreground mt-1 text-sm">{entry.data.description}</p>
              </Card>
            ))}
          </ul>
        </section>
      )
    }

    {
      upcoming.length > 0 && (
        <section class="mt-16">
          <div class="flex items-baseline justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight">{t('home.upcomingTalks')}</h2>
            <a
              href={`/${locale}/talks`}
              class="text-muted-foreground hover:text-foreground font-mono text-xs"
            >
              {t('talks.allTalks')} →
            </a>
          </div>
          <ul class="mt-6 space-y-6">
            {upcoming.map(({ slug, entry }) => (
              <li class="border-border border-b pb-6 last:border-0">
                <h3 class="font-semibold tracking-tight">
                  <a href={`/${locale}/talks/${slug}`} class="hover:text-primary transition-colors">
                    {entry.data.title}
                  </a>
                </h3>
                <p class="text-muted-foreground mt-1 font-mono text-xs">
                  <time datetime={isoDate(entry.data.startDate)}>
                    {formatDate(entry.data.startDate, locale, 'medium')}
                  </time>
                  {entry.data.location && <span> · {entry.data.location}</span>}
                </p>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </Container>
</BaseLayout>
