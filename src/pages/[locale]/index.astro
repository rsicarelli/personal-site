---
/**
 * Home hub (#29, redesigned as the inviting wave hero + guided paths) — opens with a full-bleed
 * generative cover (the same contour art that signs every post and series) carrying the serif
 * name, the positioning line and two CTAs: start the canonical first series, or meet the author.
 * A computed stats band (never hardcoded — counted from the collections at build) backs the
 * invitation with proof, then the learning paths take the centerpiece, followed by the featured
 * deep-dive, and a combined projects + next-appearance section. Sections render only when they
 * have content (draft-filtered in prod); the newsletter band already lives in the footer.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Card from '@/components/ui/Card.astro';
import Cover from '@/components/content/Cover.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import PostCard from '@/components/content/PostCard.astro';
import SeriesSpotlight from '@/components/content/SeriesSpotlight.astro';
import { LOCALES, SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { websiteLd, personLd } from '@/lib/jsonld';
import {
  getLocalizedEntries,
  getLocalizedEntry,
  getSeriesWithCounts,
  commonBlogTagSlugs,
} from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);

// Site-wide graph (#52): WebSite + the rich Person, so the home page asserts the site/author
// identity. The Person is the same node the About page emits — both built from the shared CV.
const homeUrl = canonicalUrl('/', locale, Astro.site);
const cv = await getLocalizedEntry('cv', locale, 'cv');
const siteGraph = [
  websiteLd({ url: homeUrl, name: SITE.title, locale }),
  ...(cv ? [personLd(cv.entry.data, { url: canonicalUrl('/about', locale, Astro.site) })] : []),
];

const allPosts = await getLocalizedEntries('blog', locale);
const featured = allPosts
  .filter((p) => p.entry.data.featured)
  .sort(
    (a, b) =>
      (a.entry.data.featuredOrder ?? Number.MAX_SAFE_INTEGER) -
      (b.entry.data.featuredOrder ?? Number.MAX_SAFE_INTEGER),
  )[0];
const tagPages = await commonBlogTagSlugs();
const seriesList = await getSeriesWithCounts(locale);
const seriesLabel = new Map(seriesList.map((s) => [s.slug, s.data.label]));
// The primary CTA targets the canonical entry path (same pointer as the blog hub's "start here").
const startHere = seriesList.find((s) => s.slug === 'kmp-101') ?? seriesList[0];

const projects = await getLocalizedEntries('portfolio', locale);
const featuredProjects = projects.filter((p) => p.entry.data.featured).slice(0, 2);

// One appearance, never an empty slot: the soonest upcoming talk, or the latest past one.
const now = new Date();
const events = await getLocalizedEntries('events', locale);
const upcoming = events
  .filter((e) => (e.entry.data.endDate ?? e.entry.data.startDate) >= now)
  .sort((a, b) => a.entry.data.startDate.getTime() - b.entry.data.startDate.getTime())[0];
const nextTalk = upcoming ?? events[0];

// Proof points, counted — the band stays honest as content grows.
const stats = [
  { value: allPosts.length, label: t('home.stats.articles') },
  { value: seriesList.length, label: t('home.stats.series') },
  { value: events.length, label: t('home.stats.talks') },
  { value: projects.length, label: t('home.stats.projects') },
];

const credentials = [
  { label: t('home.credential.role'), href: `/${locale}/about` },
  { label: t('home.credential.speaker'), href: `/${locale}/talks` },
  { label: t('home.credential.oss'), href: `/${locale}/projects` },
];

const sectionLabel = 'text-muted-foreground text-xs font-semibold tracking-wide uppercase';
const sectionLink =
  'text-muted-foreground hover:text-foreground font-mono text-xs transition-colors';
---

<BaseLayout title={t('site.title')} description={t('site.description')}>
  <JsonLd slot="head" schema={siteGraph} />

  {/* Full-bleed wave hero — the site's generative signature, edge to edge. The scrim mirrors
      CoverBanner's (opaque at the bottom, fading up) so the copy stays readable in BOTH themes. */}
  <section class="border-border relative isolate overflow-hidden border-b">
    <Cover seed="rodrigo-sicarelli" bare class="absolute inset-0 h-full w-full" />
    <div
      class="from-background via-background/80 to-background/30 pointer-events-none absolute inset-0 bg-gradient-to-t"
    >
    </div>
    <Container class="relative z-10 pt-20 pb-12 sm:pt-28 sm:pb-16">
      <p class="text-muted-foreground font-mono text-xs tracking-wide uppercase">
        {t('home.eyebrow')}
      </p>
      <h1 class="mt-3 font-serif text-4xl font-bold tracking-tight text-balance sm:text-6xl">
        {t('home.heading')}
      </h1>
      <p class="text-foreground/80 mt-4 max-w-prose text-lg text-pretty sm:text-xl">
        {t('home.intro')}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        {
          startHere && (
            <a
              href={startHere.href}
              class="bg-primary text-primary-foreground hover:bg-primary/90 focus-visible:ring-ring/50 inline-flex items-center rounded-md px-4 py-2 text-sm font-medium transition-colors focus-visible:ring-[3px] focus-visible:outline-none"
            >
              {t('home.cta.start')} →
            </a>
          )
        }
        <a
          href={`/${locale}/about`}
          class="border-border hover:bg-secondary/60 focus-visible:ring-ring/50 inline-flex items-center rounded-md border px-4 py-2 text-sm font-medium transition-colors focus-visible:ring-[3px] focus-visible:outline-none"
        >
          {t('home.cta.about')}
        </a>
      </div>
      <ul class="mt-8 flex flex-wrap gap-2 text-xs">
        {
          credentials.map((c) => (
            <li>
              <a
                href={c.href}
                class="border-border bg-background/65 text-muted-foreground hover:text-foreground rounded-full border px-3 py-1 backdrop-blur-sm transition-colors"
              >
                {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  {/* Computed proof band — numbers from the collections, not copy. */}
  <Container class="py-10">
    <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {
        stats.map((s) => (
          <div class="flex flex-col-reverse">
            <dt class="text-muted-foreground mt-1 text-xs font-semibold tracking-wide uppercase">
              {s.label}
            </dt>
            <dd class="font-mono text-2xl font-semibold tracking-tight tabular-nums sm:text-3xl">
              {s.value}
            </dd>
          </div>
        ))
      }
    </dl>
  </Container>

  <Container class="border-border border-t pt-4 pb-16">
    <SeriesSpotlight locale={locale} series={seriesList} heading={t('home.paths')} />

    {
      featured && (
        <section aria-labelledby="home-featured" class="mt-14">
          <h2 id="home-featured" class={sectionLabel}>
            {t('blog.featured')}
          </h2>
          <div class="mt-4">
            <PostCard
              locale={locale}
              slug={featured.slug}
              entry={featured.entry}
              seriesLabel={
                featured.entry.data.series ? seriesLabel.get(featured.entry.data.series) : undefined
              }
              tagPages={tagPages}
              eager
            />
          </div>
        </section>
      )
    }

    <div class="mt-14 grid gap-10 sm:grid-cols-2">
      {
        featuredProjects.length > 0 && (
          <section aria-labelledby="home-projects">
            <div class="flex items-baseline justify-between gap-4">
              <h2 id="home-projects" class={sectionLabel}>
                {t('home.featuredProjects')}
              </h2>
              <a href={`/${locale}/projects`} class={sectionLink}>
                {t('projects.allProjects')} →
              </a>
            </div>
            <ul class="mt-4 space-y-4">
              {featuredProjects.map(({ slug, entry }) => (
                <li>
                  <Card href={`/${locale}/projects/${slug}`}>
                    <h3 class="font-mono font-semibold tracking-tight">{entry.data.title}</h3>
                    <p class="text-muted-foreground mt-1 text-sm">{entry.data.description}</p>
                  </Card>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        nextTalk && (
          <section aria-labelledby="home-talk">
            <div class="flex items-baseline justify-between gap-4">
              <h2 id="home-talk" class={sectionLabel}>
                {upcoming ? t('home.upcomingTalks') : t('home.latestTalk')}
              </h2>
              <a href={`/${locale}/talks`} class={sectionLink}>
                {t('talks.allTalks')} →
              </a>
            </div>
            <Card href={`/${locale}/talks/${nextTalk.slug}`} class="mt-4">
              <p class="text-muted-foreground font-mono text-xs">
                <time datetime={isoDate(nextTalk.entry.data.startDate)}>
                  {formatDate(nextTalk.entry.data.startDate, locale)}
                </time>
                {nextTalk.entry.data.location && <span> · {nextTalk.entry.data.location}</span>}
              </p>
              <h3 class="mt-1 font-semibold tracking-tight">{nextTalk.entry.data.title}</h3>
              <p class="text-muted-foreground mt-2 text-sm">{nextTalk.entry.data.description}</p>
            </Card>
          </section>
        )
      }
    </div>
  </Container>
</BaseLayout>
