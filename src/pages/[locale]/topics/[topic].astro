---
/**
 * Topic hub (#231 D1) — `/<locale>/topics/<slug>`, one per controlled topic with published posts.
 * The primary browse facet: a unique answer-first intro, then the topic's posts via the shared
 * `PostCard`, plus CollectionPage + ItemList + breadcrumb structured data. Only topics with ≥1
 * published post get a page (so an empty topic never ships), and that set is identical across locales
 * (posts are bilingual) so BaseLayout's reciprocal hreflang always has a real sibling.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import PostCard from '@/components/content/PostCard.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { LOCALES, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import type { UIKey } from '@/i18n/ui';
import {
  getLocalizedEntries,
  getTopicsWithCounts,
  getSeriesWithCounts,
  commonBlogTagSlugs,
  type Topic,
} from '@/lib/content';
import { canonicalUrl } from '@/lib/seo';
import { collectionPageLd, breadcrumbLd } from '@/lib/jsonld';

export async function getStaticPaths() {
  const paths: { params: { locale: Locale; topic: string } }[] = [];
  for (const locale of LOCALES) {
    for (const { topic } of await getTopicsWithCounts(locale)) {
      paths.push({ params: { locale, topic } });
    }
  }
  return paths;
}

const locale = Astro.params.locale as Locale;
const topic = Astro.params.topic as Topic;
const t = useTranslations(locale);
const label = t(`blog.topic.${topic}` as UIKey);
const intro = t(`topic.intro.${topic}` as UIKey);

const posts = (await getLocalizedEntries('blog', locale)).filter(
  (p) => p.entry.data.topic === topic,
);
const tagPages = await commonBlogTagSlugs();
const seriesLabel = new Map((await getSeriesWithCounts(locale)).map((s) => [s.slug, s.data.label]));

// Structured data (#231 D1): CollectionPage + ItemList of the topic's posts + Home → Blog → topic.
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
const items = posts.map(({ slug, entry }) => ({
  url: canonicalUrl(`/blog/${slug}`, locale, Astro.site),
  name: entry.data.title,
}));
const jsonLd = [
  collectionPageLd({ url: pageUrl, name: label, locale, description: intro, items }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.blog'), url: canonicalUrl('/blog', locale, Astro.site) },
    { name: label, url: pageUrl },
  ]),
];
---

<BaseLayout title={`${label} · ${t('site.title')}`} description={intro}>
  <JsonLd slot="head" schema={jsonLd} />
  <Container as="section" class="py-16">
    <a
      href={`/${locale}/blog`}
      class="text-muted-foreground hover:text-foreground font-mono text-xs"
    >
      ← {t('blog.allPosts')}
    </a>
    <h1 class="mt-6 text-3xl font-bold tracking-tight">{label}</h1>
    <p class="text-foreground/80 mt-3 max-w-prose text-lg">{intro}</p>

    <div class="mt-10 space-y-10">
      {
        posts.map(({ slug, entry }, i) => (
          <PostCard
            locale={locale}
            slug={slug}
            entry={entry}
            seriesLabel={entry.data.series ? seriesLabel.get(entry.data.series) : undefined}
            tagPages={tagPages}
            eager={i === 0}
          />
        ))
      }
    </div>
  </Container>
</BaseLayout>
