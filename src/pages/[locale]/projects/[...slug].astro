---
/**
 * Project detail (#33). One route per (locale, project) from the content spine. Renders the MDX
 * write-up plus the tech stack and a link to the source repository.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { creativeWorkLd, breadcrumbLd } from '@/lib/jsonld';
import { localizedPaths } from '@/lib/content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  return localizedPaths('portfolio');
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;
const t = useTranslations(locale);
const { Content } = await render(entry);
const { title, description, tech, repo, cover } = entry.data;

// Pagefind index metadata (Option A search) — see the blog detail page for the full rationale.
// Projects have no date; the meta line is up to 3 tech tokens, joined here for the result card.
const pfTypeLabel = t('search.type.project');
const pfTech = tech.slice(0, 3).join(' · ');

// Structured data (#52): SoftwareSourceCode (repo present) or CreativeWork, plus a breadcrumb.
// OG/JSON-LD image: the local cover when present, else a per-page generated card (#148) — both
// self-hosted (the metadata suite asserts the rsicarelli.com origin).
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
const ogImage = cover
  ? new URL(cover.src, Astro.site).href
  : new URL(`/og/${locale}/portfolio/${slug}.png`, Astro.site).href;
const jsonLd = [
  creativeWorkLd(entry.data, { url: pageUrl, locale, authorName: SITE.name, image: ogImage }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.projects'), url: canonicalUrl('/projects', locale, Astro.site) },
    { name: title, url: pageUrl },
  ]),
];
---

<BaseLayout
  title={`${title} · ${t('site.title')}`}
  description={description}
  ogType="article"
  image={ogImage}
>
  <JsonLd slot="head" schema={jsonLd} />
  {
    /* `data-pagefind-body` marks this article as the search corpus; the data-pagefind-meta spans
    below bake the localized labels + meta-line tech for the result card (see blog detail). */
  }
  <Container as="article" class="py-16" data-pagefind-body data-pagefind-filter="type:project">
    <span hidden data-pagefind-meta={`typeLabel:${pfTypeLabel}`}></span>
    <span hidden data-pagefind-meta={`excerpt:${description}`}></span>
    {pfTech && <span hidden data-pagefind-meta={`tech:${pfTech}`} />}
    <a
      href={`/${locale}/projects`}
      data-pagefind-ignore
      class="text-muted-foreground hover:text-foreground font-mono text-xs"
    >
      ← {t('projects.allProjects')}
    </a>
    <h1
      class="mt-6 font-mono text-3xl font-bold tracking-tight"
      data-pagefind-meta="title"
      data-pagefind-weight="10"
    >
      {title}
    </h1>
    <p class="text-muted-foreground mt-3 max-w-prose">{description}</p>

    {
      tech.length > 0 && (
        <ul class="text-muted-foreground mt-4 flex flex-wrap gap-2 font-mono text-xs">
          {tech.map((item) => (
            <li class="border-border rounded-full border px-2 py-0.5">{item}</li>
          ))}
        </ul>
      )
    }

    {
      repo && (
        <a
          href={repo}
          rel="noopener"
          class="text-primary mt-6 inline-flex font-mono text-sm underline underline-offset-4"
        >
          {t('projects.viewSource')} ↗
        </a>
      )
    }

    <Prose class="mt-8">
      <Content />
    </Prose>
  </Container>
</BaseLayout>
