---
/**
 * Projects / OSS index (#33) — portfolio entries per locale, featured first. Cards use semantic
 * tokens; they swap to Epic 5's card component when it lands. Repo links open the source on GitHub.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LOCALES, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { getLocalizedEntries } from '@/lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const projects = (await getLocalizedEntries('portfolio', locale)).sort(
  (a, b) => Number(b.entry.data.featured) - Number(a.entry.data.featured),
);
---

<BaseLayout title={`${t('nav.projects')} · ${t('site.title')}`} description={t('site.description')}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight">{t('nav.projects')}</h1>

    {projects.length === 0 && <p class="text-muted-foreground mt-6">{t('projects.empty')}</p>}

    <ul class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        projects.map(({ slug, entry }) => (
          <li class="border-border bg-card flex flex-col rounded-lg border p-5">
            <div class="flex items-baseline justify-between gap-3">
              <h2 class="font-mono text-lg font-semibold tracking-tight">
                <a
                  href={`/${locale}/projects/${slug}`}
                  class="hover:text-primary transition-colors"
                >
                  {entry.data.title}
                </a>
              </h2>
              {entry.data.featured && (
                <span class="text-primary border-primary/30 shrink-0 rounded-full border px-2 py-0.5 text-[0.65rem] tracking-wide uppercase">
                  {t('projects.featured')}
                </span>
              )}
            </div>
            <p class="text-muted-foreground mt-2 grow text-sm">{entry.data.description}</p>
            {entry.data.tech.length > 0 && (
              <ul class="text-muted-foreground mt-4 flex flex-wrap gap-2 font-mono text-xs">
                {entry.data.tech.map((tech) => (
                  <li class="border-border rounded-full border px-2 py-0.5">{tech}</li>
                ))}
              </ul>
            )}
            {entry.data.repo && (
              <a
                href={entry.data.repo}
                rel="noopener"
                class="text-muted-foreground hover:text-foreground mt-4 inline-flex font-mono text-xs underline underline-offset-4"
              >
                {t('projects.viewSource')} ↗
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
