---
/**
 * Talk / event detail (#34). One route per (locale, event) from the content spine. Renders the
 * recording through the lightweight YouTube facade (loads on click), plus date, location, slides
 * and the event page. The facade is a page-owned stub; it swaps to Epic 5's lite-youtube later.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
import LiteYouTube from '@/components/ui/LiteYouTube.astro';
import { type Locale } from '@/config/site';
import { useTranslations, hreflangOf } from '@/i18n/utils';
import { localizedPaths } from '@/lib/content';
import { youtubeId } from '@/lib/media';
import { render } from 'astro:content';

export async function getStaticPaths() {
  return localizedPaths('events');
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const { Content } = await render(entry);
const { title, description, startDate, endDate, location, url, slides, video } = entry.data;
const videoId = video ? youtubeId(video) : null;
// timeZone UTC: content dates are date-only (UTC midnight); local-zone formatting would shift the
// calendar day (e.g. a 2024-07-29 talk showing as Jul 28).
const df = new Intl.DateTimeFormat(hreflangOf(locale), { dateStyle: 'long', timeZone: 'UTC' });
const dateLabel =
  endDate && endDate.getTime() !== startDate.getTime()
    ? `${df.format(startDate)} – ${df.format(endDate)}`
    : df.format(startDate);
---

<BaseLayout title={`${title} · ${t('site.title')}`} description={description}>
  <Container as="article" class="py-16">
    <a
      href={`/${locale}/talks`}
      class="text-muted-foreground hover:text-foreground font-mono text-xs"
    >
      ← {t('talks.allTalks')}
    </a>
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-balance">{title}</h1>
    <p class="text-muted-foreground mt-3 font-mono text-xs">
      <time datetime={startDate.toISOString()}>{dateLabel}</time>
      {location && <span> · {location}</span>}
    </p>

    {videoId && <LiteYouTube id={videoId} title={title} class="mt-8" />}

    <p class="text-muted-foreground mt-8 max-w-prose">{description}</p>

    <div class="mt-6 flex flex-wrap gap-4 font-mono text-sm">
      {
        slides && (
          <a href={slides} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.slides')} ↗
          </a>
        )
      }
      {
        video && (
          <a href={video} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.watch')} ↗
          </a>
        )
      }
      {
        url && (
          <a href={url} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.eventPage')} ↗
          </a>
        )
      }
    </div>

    <Prose class="mt-8">
      <Content />
    </Prose>
  </Container>
</BaseLayout>
