---
/**
 * Talk / event detail (#34). One route per (locale, event) from the content spine. Renders the
 * recording through the lightweight YouTube facade (loads on click), plus date, location, slides
 * and the event page. The facade is a page-owned stub; it swaps to Epic 5's lite-youtube later.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
import LiteYouTube from '@/components/ui/LiteYouTube.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { eventLd, breadcrumbLd } from '@/lib/jsonld';
import { localizedPaths } from '@/lib/content';
import { youtubeId } from '@/lib/media';
import { formatDate, isoDate } from '@/lib/datetime';
import { render } from 'astro:content';

export async function getStaticPaths() {
  return localizedPaths('events');
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;
const t = useTranslations(locale);
const { Content } = await render(entry);
const { title, description, startDate, endDate, location, url, slides, video } = entry.data;
const videoId = video ? youtubeId(video) : null;
const dateLabel =
  endDate && endDate.getTime() !== startDate.getTime()
    ? `${formatDate(startDate, locale)} – ${formatDate(endDate, locale)}`
    : formatDate(startDate, locale);

// Structured data (#52): Event (Offline when a venue is set, else VirtualLocation) + breadcrumb.
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
// Talks have no image field → a per-page generated OG card (#148), self-hosted on our origin.
const ogImage = new URL(`/og/${locale}/events/${slug}.png`, Astro.site).href;
const jsonLd = [
  eventLd(entry.data, { url: pageUrl, locale, performerName: SITE.name }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.talks'), url: canonicalUrl('/talks', locale, Astro.site) },
    { name: title, url: pageUrl },
  ]),
];
---

<BaseLayout
  title={`${title} · ${t('site.title')}`}
  description={description}
  ogType="article"
  image={ogImage}
>
  <JsonLd slot="head" schema={jsonLd} />
  <Container as="article" class="py-16">
    <a
      href={`/${locale}/talks`}
      class="text-muted-foreground hover:text-foreground font-mono text-xs"
    >
      ← {t('talks.allTalks')}
    </a>
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-balance">{title}</h1>
    <p class="text-muted-foreground mt-3 font-mono text-xs">
      <time datetime={isoDate(startDate)}>{dateLabel}</time>
      {location && <span> · {location}</span>}
    </p>

    {videoId && <LiteYouTube id={videoId} title={title} class="mt-8" />}

    <p class="text-muted-foreground mt-8 max-w-prose">{description}</p>

    <div class="mt-6 flex flex-wrap gap-4 font-mono text-sm">
      {
        slides && (
          <a href={slides} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.slides')} ↗
          </a>
        )
      }
      {
        video && (
          <a href={video} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.watch')} ↗
          </a>
        )
      }
      {
        url && (
          <a href={url} rel="noopener" class="text-primary underline underline-offset-4">
            {t('talks.eventPage')} ↗
          </a>
        )
      }
    </div>

    <Prose class="mt-8">
      <Content />
    </Prose>
  </Container>
</BaseLayout>
