---
/**
 * Blog post (#31). One route per (locale, post) from the content spine. Reading time comes from the
 * remark plugin via render()'s remarkPluginFrontmatter (computed, not authored). Tags link to their
 * archive only when the tag exists in both locales. Prose styling adopts Epic 5's typography later.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import PostSummary from '@/components/content/PostSummary.astro';
import ViewBeacon from '@/components/content/ViewBeacon.astro';
import EngagementBeacon from '@/components/content/EngagementBeacon.astro';
import Reactions from '@/components/content/Reactions.astro';
import ShareButtons from '@/components/content/ShareButtons.astro';
import AuthorCard from '@/components/content/AuthorCard.astro';
import TableOfContents from '@/components/content/TableOfContents.astro';
import NewsletterSignup from '@/components/content/NewsletterSignup.astro';
import Comments from '@/components/content/Comments.astro';
import { SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { blogPostingLd, breadcrumbLd } from '@/lib/jsonld';
import {
  localizedPaths,
  commonBlogTagSlugs,
  slugifyTag,
  getSeriesPosts,
  getLocalizedEntry,
} from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';
import type { UIKey } from '@/i18n/ui';
import { render } from 'astro:content';

export async function getStaticPaths() {
  return localizedPaths('blog');
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;
const t = useTranslations(locale);
const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const minutes = remarkPluginFrontmatter.minutesRead as number;
// "On this page" TOC (web.dev/MDN model): list h2/h3, but only bother for genuinely long posts —
// ≥3 H2s — so short notes stay a clean single column. `render()` auto-slugs the heading `id`s, so
// the anchors resolve with zero JS.
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = headings.filter((h) => h.depth === 2).length >= 3;
const tagPages = await commonBlogTagSlugs();
const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  cover,
  summary,
  series,
  translated,
  comments,
  reactions,
  discuss,
  provenance,
} = entry.data;

// Series context: the part badge (linking to the series landing) + prev/next-in-series nav, derived
// from sibling posts ordered by `seriesOrder` (regenerates the ⬅️➡️ nav that ingestion strips).
const seriesPosts = series ? await getSeriesPosts(locale, series) : [];
const seriesInfo = series ? await getLocalizedEntry('series', locale, series) : undefined;
const idx = seriesPosts.findIndex((p) => p.slug === slug);
const prev = idx > 0 ? seriesPosts[idx - 1] : undefined;
const next = idx >= 0 && idx < seriesPosts.length - 1 ? seriesPosts[idx + 1] : undefined;

// Structured data (#52): BlogPosting + a Home → Blog → post breadcrumb. The post's cover (when
// present) becomes both the OG image and BlogPosting.image; dates reuse the same UTC source as the
// visible <time> elements. Author is name-only here; the rich Person node lives on /about.
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
const postPath = new URL(pageUrl).pathname;
// Source-repo byline link. (The dev.to attribution link was dropped with the cover migration; the
// canonical/syndication tie still lives in `provenance.devtoUrl` + the write-back script.)
const sourceUrl = provenance?.githubBranch ?? provenance?.githubRepo;
// OG/JSON-LD image must be self-hosted (the metadata suite asserts the rsicarelli.com origin). Use
// the local optimized `cover` when present; otherwise a per-post generated card (#148) on our own
// origin.
const ogImage = cover
  ? new URL(cover.src, Astro.site).href
  : new URL(`/og/${locale}/blog/${slug}.png`, Astro.site).href;
const seriesUrl = series ? canonicalUrl(`/series/${series}`, locale, Astro.site) : undefined;
const jsonLd = [
  blogPostingLd(entry.data, {
    url: pageUrl,
    locale,
    authorName: SITE.name,
    image: ogImage,
    seriesName: seriesInfo?.entry.data.label,
    seriesUrl,
  }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.blog'), url: canonicalUrl('/blog', locale, Astro.site) },
    ...(series && seriesInfo ? [{ name: seriesInfo.entry.data.label, url: seriesUrl! }] : []),
    { name: title, url: pageUrl },
  ]),
];

// Pagefind index metadata (Option A search). The island reads these back from `result.data().meta`
// to rebuild the result card WITHOUT re-deriving i18n at runtime: localized type/topic labels and
// the formatted date are baked here at build time. `excerpt` is the answer-first capsule (`summary`
// ?? `description`), matching the shared `SearchDoc.excerpt`. The meta line is date · X min · topic.
const topicLabel = t(`blog.topic.${entry.data.topic}` as UIKey);
const pfTypeLabel = t('search.type.blog');
const pfExcerpt = summary ?? description;
---

<BaseLayout
  title={`${title} · ${t('site.title')}`}
  description={description}
  ogType="article"
  image={ogImage}
  noindex={translated === false}
>
  <JsonLd slot="head" schema={jsonLd} />
  {
    /*
    Breakout grid: a centered reading column (~48rem) with a sticky "On this page" rail beside it on
    desktop (only when the post is long enough to warrant one). Below `lg`, or for short posts, this
    is just the editorial reading column — same width + gutter as `container-content`. DOM order stays
    reading-logical: the <aside> follows the <article>, CSS Grid places it to the side.
  */
  }
  <div
    class:list={[
      'mx-auto w-full max-w-[48rem] px-6 py-16 sm:px-8',
      showToc &&
        'lg:grid lg:max-w-[66rem] lg:grid-cols-[minmax(0,48rem)_15rem] lg:justify-center lg:gap-x-12',
    ]}
  >
    {
      /* `data-pagefind-body` marks this article as the search corpus (once any page is tagged,
      untagged pages — listings, tags, home — drop out of the index automatically). Filters +
      display metadata are emitted via the data-pagefind-* spans just below; chrome inside the
      article (back link, series nav, TOC, engagement zone, tags, comments) carries
      `data-pagefind-ignore` so only the prose + title feed the index and the excerpt. */
    }
    <article class="min-w-0" data-pagefind-body data-pagefind-filter="type:blog">
      {
        /* Indexable display metadata (zero visual output): localized labels + the formatted date,
        read back by the search island to rebuild the result card. The title is also emitted as a
        meta field AND weighted up on the <h1> below. */
      }
      <span hidden data-pagefind-meta={`typeLabel:${pfTypeLabel}`}></span>
      <span hidden data-pagefind-meta={`excerpt:${pfExcerpt}`}></span>
      <span hidden data-pagefind-meta={`dateIso:${isoDate(pubDate)}`}></span>
      <span hidden data-pagefind-meta={`dateLabel:${formatDate(pubDate, locale)}`}></span>
      <span hidden data-pagefind-meta={`minRead:${minutes} ${t('blog.minRead')}`}></span>
      <span hidden data-pagefind-meta={`topicLabel:${topicLabel}`}></span>
      <a
        href={`/${locale}/blog`}
        data-pagefind-ignore
        class="text-muted-foreground hover:text-foreground font-mono text-xs"
      >
        ← {t('blog.allPosts')}
      </a>
      {
        series && seriesInfo && (
          <p class="mt-6 font-mono text-xs" data-pagefind-ignore>
            <a
              href={`/${locale}/series/${series}`}
              class="bg-secondary text-secondary-foreground hover:bg-secondary/70 inline-flex rounded-md px-1.5 py-0.5 transition-colors"
            >
              {seriesInfo.entry.data.label}
              {entry.data.seriesOrder != null && ` · ${t('blog.part')} ${entry.data.seriesOrder}`}
            </a>
          </p>
        )
      }
      <h1
        class="mt-3 font-serif text-3xl font-bold tracking-tight text-balance"
        data-pagefind-meta="title"
        data-pagefind-weight="10"
      >
        {title}
      </h1>
      <p class="text-muted-foreground mt-3 font-mono text-xs" data-pagefind-ignore>
        {
          /* Visible byline (#59) — pairs with the BlogPosting.author Person ref; links to /about. */
        }
        {t('blog.by')}{' '}
        <a
          href={`/${locale}/about`}
          rel="author"
          class="hover:text-foreground underline underline-offset-4"
        >
          {SITE.name}
        </a>
        <span aria-hidden="true"> · </span>
        <time datetime={isoDate(pubDate)}>{formatDate(pubDate, locale)}</time>
        <span aria-hidden="true"> · </span>{minutes}
        {t('blog.minRead')}
        {
          updatedDate && (
            <>
              <span aria-hidden="true"> · </span>
              {t('blog.updated')}{' '}
              <time datetime={isoDate(updatedDate)}>{formatDate(updatedDate, locale)}</time>
            </>
          )
        }
      </p>

      {
        /* Source repo link (the dev.to attribution link was dropped with the cover migration; the
          canonical/syndication relationship still lives in provenance + the write-back script). */
        sourceUrl && (
          <p
            class="text-muted-foreground mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs"
            data-pagefind-ignore
          >
            <a
              href={sourceUrl}
              rel="noopener"
              target="_blank"
              class="hover:text-foreground underline underline-offset-4"
            >
              ↗ {t('blog.sourceCode')}
            </a>
          </p>
        )
      }

      {
        /* Answer-first capsule (#56), now a clearly-labeled TL;DR (no longer a blockquote look-alike). */
        summary && <PostSummary summary={summary} locale={locale} class="mt-6" />
      }

      {
        /* Mobile-only "On this page": a collapsible block at the top of the article (the desktop rail
        lives beside the column instead). Reading stays uninterrupted — no pre-read CTAs. */
        showToc && (
          <div data-pagefind-ignore>
            <TableOfContents
              headings={tocHeadings}
              locale={locale}
              variant="inline"
              class="mt-6 lg:hidden"
            />
          </div>
        )
      }

      <ViewBeacon path={postPath} />

      {
        translated === false && (
          <p class="border-border text-muted-foreground mt-6 rounded-lg border border-dashed px-4 py-3 text-sm">
            {t('blog.originalLanguage')}
          </p>
        )
      }

      <Prose class="mt-8">
        <Content />
      </Prose>

      {
        /* End-of-article sentinel + engaged-time/read-complete beacon (#224). Renders nothing visible. */
      }
      <EngagementBeacon path={postPath} />

      {
        /*
      Post-read engagement zone — one bounded region at peak intent. Low-commitment signals first
      (react + share), then credibility (author), then the single primary CTA (newsletter, the one
      accent fill). Reciprocity + peak-end: the ask lands after the value is delivered.
    */
      }
      <div class="border-border mt-12 flex flex-col gap-8 border-t pt-10" data-pagefind-ignore>
        {reactions !== false && <Reactions path={postPath} locale={locale} />}
        <ShareButtons url={pageUrl} title={title} locale={locale} />
        <AuthorCard locale={locale} />
        <NewsletterSignup locale={locale} bare />
      </div>

      {
        tags.length > 0 && (
          <footer class="border-border mt-12 border-t pt-6" data-pagefind-ignore>
            <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
              {t('blog.tags')}
            </h2>
            <ul class="mt-3 flex flex-wrap gap-2 text-xs">
              {tags.map((tag) =>
                tagPages.has(slugifyTag(tag)) ? (
                  <li>
                    <a
                      href={`/${locale}/blog/tags/${slugifyTag(tag)}`}
                      class="border-border text-muted-foreground hover:text-foreground rounded-full border px-2 py-0.5 transition-colors"
                    >
                      {tag}
                    </a>
                  </li>
                ) : (
                  <li class="text-muted-foreground border-border rounded-full border px-2 py-0.5">
                    {tag}
                  </li>
                ),
              )}
            </ul>
          </footer>
        )
      }

      {
        (prev || next) && (
          <nav
            aria-label={seriesInfo?.entry.data.label}
            class="border-border mt-12 grid gap-4 border-t pt-6 sm:grid-cols-2"
            data-pagefind-ignore
          >
            {prev ? (
              <a
                href={`/${locale}/blog/${prev.slug}`}
                class="group text-muted-foreground hover:text-foreground transition-colors"
              >
                <span class="font-mono text-xs">← {t('blog.previousPart')}</span>
                <span class="group-hover:text-foreground text-foreground mt-1 block font-medium">
                  {prev.entry.data.title}
                </span>
              </a>
            ) : (
              <span />
            )}
            {next && (
              <a
                href={`/${locale}/blog/${next.slug}`}
                class="group text-muted-foreground hover:text-foreground transition-colors sm:text-right"
              >
                <span class="font-mono text-xs">{t('blog.nextPart')} →</span>
                <span class="text-foreground mt-1 block font-medium">{next.entry.data.title}</span>
              </a>
            )}
          </nav>
        )
      }

      {
        /* Always offer the way back up to the series overview (the part badge at the top links there
        too, but the foot of a long read is where the reader decides what's next). */
        series && seriesInfo && (
          <p class="mt-6 text-center" data-pagefind-ignore>
            <a
              href={`/${locale}/series/${series}`}
              class="text-muted-foreground hover:text-foreground font-mono text-xs"
            >
              ↩ {t('series.backToOverview')}
            </a>
          </p>
        )
      }
    </article>

    {
      /* Sticky "On this page" rail — desktop only, beside the reading column. Quiet by default; the
        signature accent marks only the active section. Hidden (and the grid collapses) when the post
        is too short to warrant it. */
      showToc && (
        <aside class="hidden lg:block" aria-label={t('blog.onThisPage')}>
          <div class="sticky top-24">
            <TableOfContents headings={tocHeadings} locale={locale} variant="rail" />
          </div>
        </aside>
      )
    }
  </div>

  {/* Comments break out of the 48rem reading column into a wider track. */}
  <Container width="wide" as="section" class="pb-16">
    <Comments locale={locale} title={title} discuss={discuss} commentsEnabled={comments} />
  </Container>
</BaseLayout>
