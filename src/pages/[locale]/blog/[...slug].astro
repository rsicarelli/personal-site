---
/**
 * Blog post (#31). One route per (locale, post) from the content spine. Reading time comes from the
 * remark plugin via render()'s remarkPluginFrontmatter (computed, not authored). Tags link to their
 * archive only when the tag exists in both locales. Prose styling adopts Epic 5's typography later.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { canonicalUrl } from '@/lib/seo';
import { blogPostingLd, breadcrumbLd } from '@/lib/jsonld';
import { localizedPaths, commonBlogTagSlugs, slugifyTag } from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';
import { render } from 'astro:content';

export async function getStaticPaths() {
  return localizedPaths('blog');
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const { Content, remarkPluginFrontmatter } = await render(entry);
const minutes = remarkPluginFrontmatter.minutesRead as number;
const tagPages = await commonBlogTagSlugs();
const { title, description, pubDate, updatedDate, tags, cover } = entry.data;

// Structured data (#52): BlogPosting + a Home → Blog → post breadcrumb. The post's cover (when
// present) becomes both the OG image and BlogPosting.image; dates reuse the same UTC source as the
// visible <time> elements. Author is name-only here; the rich Person node lives on /about.
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
const coverUrl = cover ? new URL(cover.src, Astro.site).href : undefined;
const jsonLd = [
  blogPostingLd(entry.data, { url: pageUrl, locale, authorName: SITE.name, image: coverUrl }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.blog'), url: canonicalUrl('/blog', locale, Astro.site) },
    { name: title, url: pageUrl },
  ]),
];
---

<BaseLayout
  title={`${title} · ${t('site.title')}`}
  description={description}
  ogType="article"
  image={coverUrl}
>
  <JsonLd slot="head" schema={jsonLd} />
  <Container as="article" class="py-16">
    <a
      href={`/${locale}/blog`}
      class="text-muted-foreground hover:text-foreground font-mono text-xs"
    >
      ← {t('blog.allPosts')}
    </a>
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-balance">{title}</h1>
    <p class="text-muted-foreground mt-3 font-mono text-xs">
      <time datetime={isoDate(pubDate)}>{formatDate(pubDate, locale)}</time>
      <span aria-hidden="true"> · </span>{minutes}
      {t('blog.minRead')}
      {
        updatedDate && (
          <>
            <span aria-hidden="true"> · </span>
            {t('blog.updated')}{' '}
            <time datetime={isoDate(updatedDate)}>{formatDate(updatedDate, locale)}</time>
          </>
        )
      }
    </p>

    <Prose class="mt-8">
      <Content />
    </Prose>

    {
      tags.length > 0 && (
        <footer class="border-border mt-12 border-t pt-6">
          <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
            {t('blog.tags')}
          </h2>
          <ul class="mt-3 flex flex-wrap gap-2 text-xs">
            {tags.map((tag) =>
              tagPages.has(slugifyTag(tag)) ? (
                <li>
                  <a
                    href={`/${locale}/blog/tags/${slugifyTag(tag)}`}
                    class="border-border text-muted-foreground hover:text-foreground rounded-full border px-2 py-0.5 transition-colors"
                  >
                    {tag}
                  </a>
                </li>
              ) : (
                <li class="text-muted-foreground border-border rounded-full border px-2 py-0.5">
                  {tag}
                </li>
              ),
            )}
          </ul>
        </footer>
      )
    }
  </Container>
</BaseLayout>
