---
/**
 * Blog hub (#31, restructured into a curated front + paginated feed in #231 C3). One paginated route
 * per locale: page 1 is `/<locale>/blog`, page N is `/<locale>/blog/<N>` (numbered pagination, not
 * infinite scroll — crawlable + self-canonical). Page 1 leads with the curated front (hub statement,
 * a "start here" pointer, the series spotlight, then featured deep-dives); every page then lists the
 * chronological "Latest" feed via the shared `PostCard`. Featured posts are surfaced on the front and
 * kept out of the paginated feed so they aren't shown twice.
 *
 * hreflang reciprocity holds for free: every post is bilingual (locale-completeness), so both locales
 * paginate to the same number of pages and `/en/blog/N` ↔ `/pt-br/blog/N` always reciprocate (the
 * alternates are derived from the locale-stripped path in BaseLayout).
 */
import type { PaginateFunction, Page } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import SeriesSpotlight from '@/components/content/SeriesSpotlight.astro';
import PostCard from '@/components/content/PostCard.astro';
import JsonLd from '@/components/content/JsonLd.astro';
import { LOCALES, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import type { UIKey } from '@/i18n/ui';
import {
  getLocalizedEntries,
  getSeriesWithCounts,
  getTopicsWithCounts,
  commonBlogTagSlugs,
  type LocalizedEntry,
} from '@/lib/content';
import { canonicalUrl } from '@/lib/seo';
import { collectionPageLd, breadcrumbLd } from '@/lib/jsonld';

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  // 12 posts/page. Inlined (not a module const): Astro hoists getStaticPaths above frontmatter
  // consts, so referencing one here hits its temporal dead zone at build time.
  const out = [];
  for (const locale of LOCALES) {
    // Featured posts live on the curated front (page 1), not in the chronological feed — so they're
    // never listed twice. The featured set is identical across locales, so page counts stay in sync.
    const posts = (await getLocalizedEntries('blog', locale)).filter((p) => !p.entry.data.featured);
    out.push(...paginate(posts, { params: { locale }, pageSize: 12 }));
  }
  return out;
}

const locale = Astro.params.locale as Locale;
const { page } = Astro.props as { page: Page<LocalizedEntry<'blog'>> };
const t = useTranslations(locale);
const isFirst = page.currentPage === 1;

const tagPages = await commonBlogTagSlugs();
const seriesList = isFirst ? await getSeriesWithCounts(locale) : [];
const seriesLabel = new Map((await getSeriesWithCounts(locale)).map((s) => [s.slug, s.data.label]));
const featured = isFirst
  ? (await getLocalizedEntries('blog', locale))
      .filter((p) => p.entry.data.featured)
      .sort(
        (a, b) =>
          (a.entry.data.featuredOrder ?? Number.MAX_SAFE_INTEGER) -
          (b.entry.data.featuredOrder ?? Number.MAX_SAFE_INTEGER),
      )
  : [];
// "New here? Start with …" → the canonical entry series (the owner's default path begins at KMP 101).
const startHere = isFirst ? seriesList.find((s) => s.slug === 'kmp-101') : undefined;
const topics = isFirst ? await getTopicsWithCounts(locale) : [];

const lastPage = page.lastPage;
const pageHref = (n: number) => (n === 1 ? `/${locale}/blog` : `/${locale}/blog/${n}`);
const pageNumbers = Array.from({ length: lastPage }, (_, i) => i + 1);

// Structured data (#231 C4): this listing as a CollectionPage whose mainEntity is an ItemList of the
// posts on THIS page, plus a Home → Blog breadcrumb. Each page self-canonicalizes (BaseLayout).
const pageUrl = canonicalUrl(Astro.url.pathname, locale, Astro.site);
const items = page.data.map(({ slug, entry }) => ({
  url: canonicalUrl(`/blog/${slug}`, locale, Astro.site),
  name: entry.data.title,
}));
const jsonLd = [
  collectionPageLd({
    url: pageUrl,
    name: t('nav.blog'),
    locale,
    description: t('blog.hubIntro'),
    items,
  }),
  breadcrumbLd([
    { name: t('nav.home'), url: canonicalUrl('/', locale, Astro.site) },
    { name: t('nav.blog'), url: canonicalUrl('/blog', locale, Astro.site) },
  ]),
];

const pageTitle = isFirst
  ? `${t('nav.blog')} · ${t('site.title')}`
  : `${t('nav.blog')} — ${t('blog.page')} ${page.currentPage} · ${t('site.title')}`;
---

<BaseLayout title={pageTitle} description={t('blog.hubIntro')}>
  <JsonLd slot="head" schema={jsonLd} />
  <Container as="section" class="py-16">
    <h1 class="text-3xl font-bold tracking-tight">{t('nav.blog')}</h1>

    {
      isFirst && (
        <>
          <p class="text-foreground/80 mt-3 max-w-prose text-lg">{t('blog.hubIntro')}</p>
          {startHere && (
            <p class="text-muted-foreground mt-4 font-mono text-xs">
              {t('blog.startHere')}{' '}
              <a href={startHere.href} class="text-primary hover:underline">
                {startHere.data.label}
              </a>
            </p>
          )}

          {topics.length > 0 && (
            <nav aria-label={t('blog.browseTopics')} class="mt-8">
              <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
                {t('blog.browseTopics')}
              </h2>
              <ul class="mt-3 flex flex-wrap gap-2 text-sm">
                {topics.map(({ topic }) => (
                  <li>
                    <a
                      href={`/${locale}/topics/${topic}`}
                      class="border-border text-muted-foreground hover:text-foreground rounded-full border px-3 py-1 transition-colors"
                    >
                      {t(`blog.topic.${topic}` as UIKey)}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          <SeriesSpotlight locale={locale} series={seriesList} />

          {featured.length > 0 && (
            <section class="mt-12">
              <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
                {t('blog.featured')}
              </h2>
              <div class="mt-6 space-y-10">
                {featured.map(({ slug, entry }, i) => (
                  <PostCard
                    locale={locale}
                    slug={slug}
                    entry={entry}
                    seriesLabel={entry.data.series ? seriesLabel.get(entry.data.series) : undefined}
                    tagPages={tagPages}
                    eager={i === 0}
                  />
                ))}
              </div>
            </section>
          )}
        </>
      )
    }

    {
      /* "Latest" heading + the visible main-feed link — humans' counterpart to the head autodiscovery. */
    }
    <div class="mt-12 flex items-baseline justify-between gap-4">
      <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
        {t('blog.latest')}
      </h2>
      <a
        href={`/${locale}/rss.xml`}
        class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5 font-mono text-xs transition-colors"
      >
        <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
          <path
            d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0zM1.82 8.91v3.27c5.52 0 10 4.48 10 10h3.27c0-7.33-5.94-13.27-13.27-13.27zM1.82 2.18v3.27c9.13 0 16.55 7.42 16.55 16.55h3.27c0-10.95-8.87-19.82-19.82-19.82z"
          ></path>
        </svg>
        {t('rss.subscribe')}
      </a>
    </div>
    {
      page.data.length === 0 ? (
        <p class="text-muted-foreground mt-6">{t('blog.empty')}</p>
      ) : (
        <div class="mt-6 space-y-10">
          {page.data.map(({ slug, entry }, i) => (
            <PostCard
              locale={locale}
              slug={slug}
              entry={entry}
              seriesLabel={entry.data.series ? seriesLabel.get(entry.data.series) : undefined}
              tagPages={tagPages}
              eager={isFirst && featured.length === 0 && i === 0}
            />
          ))}
        </div>
      )
    }

    {
      lastPage > 1 && (
        <nav
          aria-label={t('blog.pagination')}
          class="border-border mt-12 flex items-center justify-between gap-4 border-t pt-6 font-mono text-xs"
        >
          {page.url.prev ? (
            <a href={page.url.prev} class="text-muted-foreground hover:text-foreground">
              ← {t('blog.newer')}
            </a>
          ) : (
            <span />
          )}
          <ul class="flex flex-wrap items-center gap-1">
            {pageNumbers.map((n) => (
              <li>
                <a
                  href={pageHref(n)}
                  aria-current={n === page.currentPage ? 'page' : undefined}
                  class:list={[
                    'rounded-md px-2 py-1 transition-colors',
                    n === page.currentPage
                      ? 'bg-secondary text-secondary-foreground'
                      : 'text-muted-foreground hover:text-foreground',
                  ]}
                >
                  {n}
                </a>
              </li>
            ))}
          </ul>
          {page.url.next ? (
            <a href={page.url.next} class="text-muted-foreground hover:text-foreground">
              {t('blog.older')} →
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </Container>
</BaseLayout>
