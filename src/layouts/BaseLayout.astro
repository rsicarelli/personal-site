---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Analytics from '@/components/Analytics.astro';
import RssLinks from '@/components/content/RssLinks.astro';
import { LOCALES, DEFAULT_LOCALE, SITE, type Locale } from '@/config/site';
import { hreflangOf, stripLocale } from '@/i18n/utils';
import { buildSeoMeta, canonicalUrl } from '@/lib/seo';

interface Props {
  /** Page <title>, already composed by the page (e.g. `About · rsicarelli.com`). */
  title: string;
  description?: string;
  /** OG/Twitter image (#51) — absolute or root-relative; defaults to the static brand card. */
  image?: string;
  /** OpenGraph type (#51) — `article` for posts/talks/projects, else `website`. */
  ogType?: 'website' | 'article';
  /** Override the social-card title; defaults to `title` minus the ` · {site}` brand suffix. */
  ogTitle?: string;
  /**
   * Keep this page out of the index (#152) — emits `robots: noindex, follow`. Used for the
   * `translated: false` blog placeholders that show original-language content until translated:
   * we don't want the wrong-language page indexed, but links should still be followed.
   */
  noindex?: boolean;
}

const { title, description, image, ogType, ogTitle, noindex } = Astro.props;

// Locale is derived from the route (`/en/…` → `en`, `/pt-br/…` → `pt-br`, bare `/` → default).
// `<html lang>` needs the RFC-5646 form (`pt-BR`), while URLs keep the lowercase slug (`pt-br`).
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const htmlLang = hreflangOf(locale);

// Reciprocal hreflang (#23). Build every alternate from the same locale-stripped logical path so
// the set is identical on `/en/…` and `/pt-br/…` (reciprocity) and the self-canonical is byte-for-
// byte the self-hreflang (no trailing-slash drift). `pt-BR` is uppercase in the attribute; the URL
// slug stays lowercase `/pt-br/`.
const logical = stripLocale(Astro.url.pathname, LOCALES);
// Shared canonical builder (#51) — the same definition pages use for JSON-LD, so they never drift.
const localeUrl = (loc: Locale) => canonicalUrl(Astro.url.pathname, loc, Astro.site);

const canonical = localeUrl(locale);
const alternates = [
  ...LOCALES.map((loc) => ({ hreflang: hreflangOf(loc), href: localeUrl(loc) })),
  {
    hreflang: 'x-default',
    // Home → the neutral gateway (the language-selection page); deeper pages → the default locale.
    href: logical === '/' ? new URL('/', Astro.site).href : localeUrl(DEFAULT_LOCALE),
  },
];

// OpenGraph / Twitter cards (#51). og:url reuses `canonical` (no re-derivation); the image
// resolves to an absolute URL (per-page/post override or the static brand card). Copy stays
// driven by the page's title/description — no hardcoded strings here.
const ogImage = new URL(image ?? '/og-default.png', Astro.site).href;
const seoMeta = buildSeoMeta({
  title,
  description,
  canonical,
  locale,
  image: ogImage,
  type: ogType ?? 'website',
  siteName: SITE.title,
  ogTitle,
});
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {
      /* Theme bootstrap (#42) — runs before first paint to set the persisted/system theme on
      <html>, so there is no flash of the wrong theme (FOUC). Re-applied on `astro:after-swap`
      (#49) because View Transitions morph <html> from the next page and would otherwise drop the
      `.dark` class mid-navigation. The ThemeToggle island keeps localStorage in sync. */
    }
    <script is:inline>
      (() => {
        const applyTheme = () => {
          try {
            const stored = localStorage.getItem('theme');
            const dark = stored
              ? stored === 'dark'
              : matchMedia('(prefers-color-scheme: dark)').matches;
            document.documentElement.classList.toggle('dark', dark);
            document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
          } catch {
            /* storage/matchMedia unavailable — fall back to the default (light) theme */
          }
        };
        applyTheme();
        if (!window.__themeSwapBound) {
          window.__themeSwapBound = true;
          document.addEventListener('astro:after-swap', applyTheme);
        }
      })();
    </script>

    {/* Same-document View Transitions (#49); reduced-motion is honoured by Astro + global.css. */}
    <ClientRouter />

    {/* Cookieless analytics (#71) — emits nothing unless both PUBLIC_UMAMI_* env vars are set. */}
    <Analytics />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {
      /* Self-hosted variable fonts (#43). Preload only Inter normal/latin — the single file that
      drives LCP body text; italic, latin-ext, and the mono accent load on demand with swap (pt-BR
      diacritics live in the `latin` subset, so preloading latin-ext would just waste bytes). */
    }
    <Font cssVariable="--font-inter" preload={[{ style: 'normal', subset: 'latin' }]} />
    <Font cssVariable="--font-jetbrains-mono" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {/* Keep wrong-language placeholders out of the index (#152); still follow their links. */}
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />

    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}

    {
      /* OpenGraph / Twitter cards (#51). hreflang above is the i18n epic's (#23) responsibility;
        detect at `/` only, keep the visible switcher. Per-page JSON-LD (#52) goes through the
        head slot below. */
    }
    {seoMeta.map((m) => <meta property={m.property} name={m.name} content={m.content} />)}

    {/* Per-locale RSS autodiscovery (#198) — site-wide so any page advertises the feed. */}
    <RssLinks locale={locale} />

    <slot name="head" />
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main-content"
      class="bg-primary text-primary-foreground sr-only rounded-md px-4 py-2 focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Skip to content
    </a>

    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>
