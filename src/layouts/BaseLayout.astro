---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  /** Page <title>. Per-locale title/description templating lands in the SEO epic (#51). */
  title: string;
  description?: string;
  /**
   * Document language. Defaults to `en` for now; the i18n epic (#19/#20) will derive this
   * from the route locale and switch the whole tree to `/en/` + `/pt-br/` subdirectories.
   */
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {
      /* SEO epic (#51/#23): reciprocal hreflang alternates (en / pt-br / x-default) +
        OpenGraph / Twitter cards are emitted here once i18n routing exists. Never a hard
        IP/locale redirect — detect at `/` only, keep a visible switcher. */
    }

    <slot name="head" />
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main-content"
      class="bg-primary text-primary-foreground sr-only rounded-md px-4 py-2 focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
