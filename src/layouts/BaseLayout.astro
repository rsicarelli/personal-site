---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { DEFAULT_LOCALE, type Locale } from '@/config/site';
import { hreflangOf } from '@/i18n/utils';

interface Props {
  /** Page <title>. Per-locale title/description templating lands in the SEO epic (#51). */
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Locale is derived from the route (`/en/…` → `en`, `/pt-br/…` → `pt-br`, bare `/` → default).
// `<html lang>` needs the RFC-5646 form (`pt-BR`), while URLs keep the lowercase slug (`pt-br`).
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const htmlLang = hreflangOf(locale);

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {
      /* SEO epic (#51/#23): reciprocal hreflang alternates (en / pt-br / x-default) +
        OpenGraph / Twitter cards are emitted here once i18n routing exists. Never a hard
        IP/locale redirect — detect at `/` only, keep a visible switcher. */
    }

    <slot name="head" />
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main-content"
      class="bg-primary text-primary-foreground sr-only rounded-md px-4 py-2 focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Skip to content
    </a>

    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>
