---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '@/config/site';
import { hreflangOf, stripLocale } from '@/i18n/utils';

interface Props {
  /** Page <title>. Per-locale title/description templating lands in the SEO epic (#51). */
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Locale is derived from the route (`/en/…` → `en`, `/pt-br/…` → `pt-br`, bare `/` → default).
// `<html lang>` needs the RFC-5646 form (`pt-BR`), while URLs keep the lowercase slug (`pt-br`).
const locale = (Astro.currentLocale ?? DEFAULT_LOCALE) as Locale;
const htmlLang = hreflangOf(locale);

// Reciprocal hreflang (#23). Build every alternate from the same locale-stripped logical path so
// the set is identical on `/en/…` and `/pt-br/…` (reciprocity) and the self-canonical is byte-for-
// byte the self-hreflang (no trailing-slash drift). `pt-BR` is uppercase in the attribute; the URL
// slug stays lowercase `/pt-br/`.
const logical = stripLocale(Astro.url.pathname, LOCALES);
const localeUrl = (loc: Locale) =>
  new URL(`/${loc}${logical === '/' ? '' : logical}`, Astro.site).href;

const canonical = localeUrl(locale);
const alternates = [
  ...LOCALES.map((loc) => ({ hreflang: hreflangOf(loc), href: localeUrl(loc) })),
  {
    hreflang: 'x-default',
    // Home → the neutral gateway (the language-selection page); deeper pages → the default locale.
    href: logical === '/' ? new URL('/', Astro.site).href : localeUrl(DEFAULT_LOCALE),
  },
];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}

    {
      /* OpenGraph / Twitter cards are emitted here in the SEO epic (#51). hreflang above is the
        i18n epic's (#23) responsibility; detect at `/` only, keep the visible switcher. */
    }

    <slot name="head" />
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main-content"
      class="bg-primary text-primary-foreground sr-only rounded-md px-4 py-2 focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Skip to content
    </a>

    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>
