---
/**
 * Footer — secondary navigation grouped into labeled columns (Explore / Personal / Subscribe),
 * per the nav evidence review (chunking beats a flat row; footer = "second-chance navigation").
 * Labels from the i18n dictionary (src/i18n/ui.ts), group structure from the central config
 * (src/config/site.ts), locale-prefixed at render. Privacy + licensing are meta, not navigation —
 * they live in the meta line next to the copyright. The Newsletter link anchors to the in-footer
 * form and only renders when the form does (PUBLIC_NEWSLETTER_ENABLED). The dynamic year is
 * computed at build time (static site), which is fine for a personal site.
 */
import { PUBLIC_NEWSLETTER_ENABLED } from 'astro:env/client';
import { FOOTER_GROUPS, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import NewsletterSignup from '@/components/content/NewsletterSignup.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const localized = (href: string) => `/${locale}${href === '/' ? '' : href}`;

const newsletterEnabled = PUBLIC_NEWSLETTER_ENABLED === 'true';
const year = new Date().getFullYear();
---

<footer class="border-border mt-16 border-t">
  <NewsletterSignup locale={locale} id="newsletter" />

  <nav aria-label={t('footer.nav')} class="container-content py-10">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      {
        FOOTER_GROUPS.map((group) => (
          <div>
            <h2 class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
              {t(group.labelKey)}
            </h2>
            <ul class="mt-3 space-y-2 text-sm">
              {group.links.map((item) => (
                <li>
                  <a
                    href={localized(item.href)}
                    class="text-muted-foreground hover:text-foreground inline-flex min-h-6 items-center transition-colors"
                  >
                    {t(item.key)}
                  </a>
                </li>
              ))}
              {group.labelKey === 'footer.group.subscribe' && newsletterEnabled && (
                <li>
                  <a
                    href="#newsletter"
                    class="text-muted-foreground hover:text-foreground inline-flex min-h-6 items-center transition-colors"
                  >
                    {t('footer.newsletter')}
                  </a>
                </li>
              )}
            </ul>
          </div>
        ))
      }
    </div>
  </nav>

  <div class="border-border text-muted-foreground container-content border-t py-6 text-sm">
    <p>
      © {year} Rodrigo Sicarelli ·
      <a
        href={localized('/licensing')}
        class="hover:text-foreground underline-offset-2 transition-colors"
      >
        {t('footer.license')}
      </a>
      <span aria-hidden="true"> · </span>
      <a
        href={localized('/privacy')}
        class="hover:text-foreground underline-offset-2 transition-colors"
      >
        {t('footer.privacy')}
      </a>
    </p>
  </div>
</footer>
