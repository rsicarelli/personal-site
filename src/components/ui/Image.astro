---
/**
 * Image (#47) — responsive image pipeline for build-optimized local images (e.g. blog/portfolio
 * `cover` fields typed as `image()`). Wraps Astro's `<Picture>` to emit AVIF + WebP with a
 * raster fallback, explicit width/height (no CLS), and lazy/eager loading.
 *
 *   import cover from '../assets/cover.jpg';
 *   <Image src={cover} alt="…" sizes="(min-width: 48rem) 48rem, 100vw"
 *          widths={[400, 800, 1200]} />
 *   <Image src={hero} alt="…" priority />   // LCP: eager + fetchpriority=high, no blur
 *
 * LQIP: a tiny (24px) WebP is generated at build via getImage and painted as a blurred
 * background behind the <img>; once the full image decodes it covers the placeholder — no JS,
 * no extra dependency. Disabled automatically for `priority` (LCP) images. Heavy remote media
 * (R2 photos/downloads via `mediaUrl()`) is intentionally NOT handled here — those stay plain
 * `<img>` with explicit dims, per src/lib/media.ts.
 */
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** A build-optimizable image import (ImageMetadata), not a remote URL string. */
  src: ImageMetadata;
  /** Alternative text (empty string only for decorative images). */
  alt: string;
  /** Candidate widths for the generated srcset. Provide `sizes` alongside it. */
  widths?: number[];
  /** The `sizes` attribute; required for meaningful art-direction when `widths` is set. */
  sizes?: string;
  /** LCP image: load eagerly with fetchpriority=high and skip the blur-up placeholder. */
  priority?: boolean;
  /** Override loading when not `priority` (defaults to lazy). */
  loading?: 'lazy' | 'eager';
  /** Blur-up placeholder for non-priority images (default true). */
  blurUp?: boolean;
  /** Extra classes merged onto the <img>. */
  class?: string;
}

const {
  src,
  alt,
  widths,
  sizes,
  priority = false,
  loading,
  blurUp = true,
  class: className,
} = Astro.props;

const showBlur = blurUp && !priority;
const lqip = showBlur ? await getImage({ src, width: 24, quality: 30, format: 'webp' }) : null;
const placeholderStyle = lqip
  ? `background-image:url('${lqip.src}');background-size:cover;background-position:center;`
  : undefined;
---

<Picture
  src={src}
  alt={alt}
  formats={['avif', 'webp']}
  widths={widths}
  sizes={sizes}
  loading={priority ? 'eager' : (loading ?? 'lazy')}
  fetchpriority={priority ? 'high' : 'auto'}
  decoding="async"
  class:list={[className]}
  style={placeholderStyle}
/>
