---
/**
 * LiteYouTube (#48) — a facade for embedding talk videos without the cost of an eager iframe.
 * Renders only a poster thumbnail + a play button; the real player (privacy-friendly
 * youtube-nocookie.com) is injected on first click. Keeps the page zero-JS until interacted
 * with (just a tiny custom-element definition) and avoids YouTube's ~hundreds of KB up front.
 *
 *   <LiteYouTube id="dQw4w9WgXcQ" title="My KotlinConf 2025 talk" />
 *
 * The poster defaults to YouTube's thumbnail; pass `poster` to self-host a higher-quality (or
 * R2-hosted) image instead. 16:9 box reserves space so there is no layout shift.
 */
interface Props {
  /** YouTube video id (the `v=` value). */
  id: string;
  /** Accessible label / play-button title (e.g. the talk name). */
  title: string;
  /** Override the poster image URL (defaults to the YouTube thumbnail). */
  poster?: string;
  /** Extra embed query params, e.g. `start=120`. `autoplay=1` is always added on activation. */
  params?: string;
  /** Extra classes on the outer element. */
  class?: string;
}

const { id, title, poster, params = '', class: className } = Astro.props;
const thumb = poster ?? `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const query = new URLSearchParams(params);
query.set('autoplay', '1');
---

<lite-youtube
  data-id={id}
  data-title={title}
  data-query={query.toString()}
  class:list={[
    'border-border bg-muted relative block aspect-video overflow-hidden rounded-lg border',
    className,
  ]}
>
  <button
    type="button"
    aria-label={`Play video: ${title}`}
    class="group absolute inset-0 h-full w-full cursor-pointer"
  >
    <img
      src={thumb}
      alt=""
      loading="lazy"
      width="1280"
      height="720"
      class="h-full w-full object-cover"
    />
    <span
      aria-hidden="true"
      class="bg-primary text-primary-foreground absolute top-1/2 left-1/2 flex size-16 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full shadow-lg transition-transform group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 size-7"
        ><path d="M8 5v14l11-7z"></path></svg
      >
    </span>
  </button>
</lite-youtube>

<script>
  class LiteYouTube extends HTMLElement {
    connectedCallback() {
      this.querySelector('button')?.addEventListener('click', () => this.activate(), {
        once: true,
      });
    }

    activate() {
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${this.dataset.id}?${this.dataset.query ?? 'autoplay=1'}`;
      iframe.title = this.dataset.title ?? 'YouTube video player';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.loading = 'lazy';
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      this.replaceChildren(iframe);
    }
  }

  if (!customElements.get('lite-youtube')) {
    customElements.define('lite-youtube', LiteYouTube);
  }
</script>
