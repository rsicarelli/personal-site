---
/**
 * Primary navigation — labels come from the i18n dictionary (src/i18n/ui.ts), hrefs from the
 * central config (src/config/site.ts) and gain a `/<locale>` prefix at render. The locale is
 * passed down from BaseLayout (derived from the route). The visible language switcher (#22)
 * sits at the end of the nav. Routes other than Home/About are placeholders until the Content
 * epic (#27).
 */
import { NAV, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

/** Prefix a logical href with the current locale: `/` → `/en`, `/blog` → `/en/blog`. */
const localized = (href: string) => `/${locale}${href === '/' ? '' : href}`;
---

<header class="border-border border-b">
  <nav aria-label="Primary" class="container-content flex items-center justify-between py-4">
    <a href={localized('/')} class="font-mono text-sm font-semibold tracking-tight">
      rsicarelli.com
    </a>
    <ul class="text-muted-foreground flex items-center gap-4 text-sm">
      {
        NAV.slice(1).map((item) => (
          <li>
            <a href={localized(item.href)} class="hover:text-foreground transition-colors">
              {t(item.key)}
            </a>
          </li>
        ))
      }
      <li class="border-border border-l pl-4">
        <LanguageSwitcher locale={locale} />
      </li>
    </ul>
  </nav>
</header>
