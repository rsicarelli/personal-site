---
/**
 * Primary navigation — labels/hrefs from the central config (src/config/site.ts).
 * Stub: routes are placeholders until the Content Architecture epic (#27) builds the pages,
 * and the language switcher + locale-prefixed hrefs arrive with the i18n epic (#22).
 */
import { NAV } from '@/config/site';
---

<header class="border-border border-b">
  <nav aria-label="Primary" class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-semibold tracking-tight">rsicarelli.com</a>
    <ul class="text-muted-foreground flex items-center gap-4 text-sm">
      {
        NAV.slice(1).map((item) => (
          <li>
            <a href={item.href} class="hover:text-foreground transition-colors">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
