---
/**
 * EngagementBeacon (#224) — cookieless engaged-time + read-complete instrumentation.
 *
 * Two first-party signals (POST /api/engagement), no cookies / no client storage:
 *   • engaged-time — accumulates VISIBLE reading time (paused while the tab is hidden) and flushes the
 *     delta via `fetch` + `keepalive` on each `visibilitychange → hidden` / `pagehide`. bfcache-safe,
 *     never `unload`/`beforeunload` (MDN guidance).
 *   • scroll depth + read-complete — invisible 1px sentinels (at 25/50/75% of the `.prose` body, plus
 *     this element at the end) fire a `depth`/`read` beacon via one IntersectionObserver when reached,
 *     each armed after a 3s dwell so an instant bounce (or a short post fully in view) doesn't count.
 *     The server dedups each milestone once per visitor/day → a read funnel (scroll_25/50/75 → read).
 *
 * Place at the END of the article body (after <Prose>). Renders nothing visible. The script reads the
 * path from `data-*` only (no interpolation) → identical bytes on every page → a stable CSP hash in
 * `public/_headers`. Instrumentation requires JS; the post reads fine without it.
 */
interface Props {
  /** The post's locale path, e.g. `/en/blog/<slug>` (server validates it against the allowlist). */
  path: string;
}
const { path } = Astro.props;
---

<div data-engagement-beacon data-engagement-path={path} aria-hidden="true"></div>

<script>
  // Bound once on astro:page-load (first load AND each View Transition swap).
  document.addEventListener('astro:page-load', () => {
    const el = document.querySelector<HTMLElement>('[data-engagement-beacon]');
    if (!el || el.dataset.engagementBound) return;
    el.dataset.engagementBound = '1';
    const path = el.getAttribute('data-engagement-path');
    if (!path) return;

    const ENDPOINT = '/api/engagement';
    const send = (body: object) => {
      try {
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
          keepalive: true,
        }).catch(() => {});
      } catch {
        /* ignore — instrumentation must never break the page */
      }
    };

    // --- engaged-time: count visible ms, flush the delta on hide ---
    let visibleSince = document.visibilityState === 'visible' ? performance.now() : 0;
    let unsentMs = 0;
    const accumulate = () => {
      if (visibleSince) {
        unsentMs += performance.now() - visibleSince;
        visibleSince = 0;
      }
    };
    const flush = () => {
      accumulate();
      const seconds = Math.round(unsentMs / 1000);
      if (seconds >= 1) {
        send({ path, kind: 'engaged', seconds });
        unsentMs = 0;
      }
    };
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') flush();
      else visibleSince = performance.now();
    });
    window.addEventListener('pagehide', flush);

    // --- scroll depth (25/50/75) + read-complete (end), via one IntersectionObserver ---
    // Each "reach" sends once, only after a 3s dwell so an instant bounce / short post in view is ignored.
    type Reach = { el: Element; body: object; vis: boolean; sent: boolean };
    const armAt = performance.now() + 3000;
    const reaches: Reach[] = [{ el, body: { path, kind: 'read' }, vis: false, sent: false }];

    // Inject invisible 1px sentinels at 25/50/75% of the READING body (`.prose`), not the whole
    // <article> (which includes the post-read engagement zone). Absolutely positioned → zero layout cost.
    const bodyEl = el.closest('article')?.querySelector<HTMLElement>('.prose');
    if (bodyEl) {
      if (getComputedStyle(bodyEl).position === 'static') bodyEl.style.position = 'relative';
      for (const pct of [25, 50, 75]) {
        const s = document.createElement('div');
        s.setAttribute('aria-hidden', 'true');
        s.style.cssText = `position:absolute;left:0;top:${pct}%;width:1px;height:1px;pointer-events:none`;
        bodyEl.appendChild(s);
        reaches.push({ el: s, body: { path, kind: 'depth', pct }, vis: false, sent: false });
      }
    }

    const flushReaches = () => {
      if (performance.now() < armAt) return;
      for (const r of reaches) {
        if (!r.sent && r.vis) {
          r.sent = true;
          send(r.body);
          io.unobserve(r.el);
        }
      }
    };
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        const r = reaches.find((x) => x.el === e.target);
        if (r) r.vis = e.isIntersecting;
      }
      flushReaches();
    });
    reaches.forEach((r) => io.observe(r.el));
    // Covers long posts (IO fires on scroll past the dwell) and short posts already fully in view.
    setTimeout(flushReaches, 3000);
  });
</script>
