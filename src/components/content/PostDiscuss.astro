---
/**
 * PostDiscuss (#196) — "Reply via email" + off-site "Discuss on…" links under a post.
 *
 * Zero-JS, no cookies: a `mailto:` to the public address (subject pre-filled with the post title) is
 * always shown — the lowest-friction "correspondent" channel from the engagement strategy — plus a
 * link per off-site thread (HN / Reddit / Lobsters / Mastodon) when set in frontmatter. Rendered as a
 * light row (no card) so it sits quietly beneath the ShareButtons card.
 */
import { useTranslations } from '@/i18n/utils';
import { SITE, type Locale } from '@/config/site';
import { discussLinks, type DiscussInput } from '@/lib/discuss';

interface Props {
  title: string;
  locale: Locale;
  discuss?: DiscussInput;
  class?: string;
}

const { title, locale, discuss, class: className } = Astro.props;
const t = useTranslations(locale);
const links = discussLinks(discuss);
const mailto = `mailto:${SITE.email}?subject=${encodeURIComponent(title)}`;

const pill =
  'inline-flex items-center gap-1.5 hover:text-foreground focus-visible:text-foreground transition-colors';

// Envelope (reply) + a single chat-bubble glyph reused for every off-site thread; the brand name is
// the visible text, so no fragile per-network brand paths are needed. Inline SVG = zero-JS.
const MAIL =
  'M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Zm21-1.762V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z';
const CHAT = 'M20 2H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h4v4l5.333-4H20a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z';
---

<nav
  aria-label={t('blog.discuss.label')}
  class:list={[
    'text-muted-foreground flex flex-wrap items-center gap-x-4 gap-y-2 text-sm',
    className,
  ]}
>
  <span class="font-medium" aria-hidden="true">{t('blog.discuss.label')}</span>

  <a href={mailto} class={pill}>
    <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
      <path d={MAIL}></path>
    </svg>
    {t('blog.discuss.reply')}
  </a>

  {
    links.map((link) => (
      <a
        href={link.href}
        aria-label={t(link.labelKey)}
        target="_blank"
        rel="noopener noreferrer"
        class={pill}
      >
        <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
          <path d={CHAT} />
        </svg>
        {link.name}
      </a>
    ))
  }
</nav>
