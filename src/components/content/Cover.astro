---
/**
 * Cover — original, self-hosted, theme-aware blog cover art (replaces the dev.to-scraped `coverUrl`).
 * An inline SVG so it's vector (infinite scale), zero-network (no request, no CLS), and re-themes for
 * free: it paints with the design tokens via Tailwind `fill-*`/`stroke-*` utilities (which resolve to
 * `var(--color-*)`), and `.dark` swaps those custom properties on `<html>`, so the art follows the
 * theme toggle with no JS and no second asset. (Token colors go through CSS classes, NOT `fill="var()"`
 * presentation attributes, which browsers don't resolve.) The art is deterministic per post via
 * `coverInputs` (src/lib/cover.ts) — stable across builds, distinct per post, one accent only
 * (geometry, not color, carries the variation).
 *
 * VARIANT: Strata — translucent accent planes stacked up-and-to-the-right, the layers deepening the
 * accent as they overlap (a "shared code across platforms / stacked layers" motif).
 *
 * Accessibility: a `label` makes it a real image (`role="img"` + `aria-label`, e.g. the series hero);
 * without one it's decorative (`aria-hidden`) because an adjacent title link is the true target.
 */
import { coverInputs } from '@/lib/cover';
import type { Topic } from '@/lib/content';

interface Props {
  /** String to seed the art (post slug, or series slug for series covers). */
  seed: string;
  topic?: Topic;
  series?: string;
  part?: number;
  /** Accessible name → renders as `role="img"`; omit for decorative covers beside a title link. */
  label?: string;
  /** Appearance classes (border / rounding / margin) — the caller owns the frame. */
  class?: string;
}

const { seed, topic, series, part, label, class: className } = Astro.props;
const { rng } = coverInputs({ slug: seed, topic, series, part });

// Stacked planes marching up-right; each higher layer adds accent opacity (overlap → depth).
const count = 4 + Math.floor(rng() * 3); // 4–6 planes
const shear = 64 + Math.floor(rng() * 70); // lean
const stepX = 64 + Math.floor(rng() * 52);
const stepY = 56 + Math.floor(rng() * 30);
const baseX = 80 + Math.floor(rng() * 130);
const baseY = 470 - Math.floor(rng() * 36);
const planeW = 470 + Math.floor(rng() * 140);
const planeH = 126 + Math.floor(rng() * 44);
const planes = Array.from({ length: count }, (_, i) => {
  const x = baseX + i * stepX + Math.round((rng() - 0.5) * 44);
  const y = baseY - i * stepY;
  const points = `${x},${y + planeH} ${x + shear},${y} ${x + shear + planeW},${y} ${x + planeW},${y + planeH}`;
  return { points, fillOpacity: (0.05 + i * 0.026).toFixed(3) };
});
---

<svg
  viewBox="0 0 1200 600"
  preserveAspectRatio="xMidYMid slice"
  class:list={['block aspect-[2/1] w-full overflow-hidden', className]}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  focusable="false"
>
  <rect class="fill-card" width="1200" height="600"></rect>
  {
    planes.map((p) => (
      <polygon
        class="fill-primary stroke-primary"
        points={p.points}
        fill-opacity={p.fillOpacity}
        stroke-opacity="0.22"
        stroke-width="1.5"
      />
    ))
  }
</svg>
