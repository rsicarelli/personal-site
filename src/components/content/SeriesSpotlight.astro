---
/**
 * SeriesSpotlight (#31) — the "Series" section that leads the blog hub: a responsive grid of
 * `SeriesCard`s, each showing parts · total reading time · level (#231 C3). Renders NOTHING when
 * there are no series with posts, so the hub degrades cleanly to a plain post list. Data comes from
 * `getSeriesWithCounts(locale)`.
 */
import SeriesCard from '@/components/content/SeriesCard.astro';
import { useTranslations } from '@/i18n/utils';
import type { Locale } from '@/config/site';
import type { UIKey } from '@/i18n/ui';
import type { SeriesWithCount } from '@/lib/content';

interface Props {
  locale: Locale;
  series: SeriesWithCount[];
  /** Section heading override (defaults to the localized "Series") — e.g. "Learning paths" on home. */
  heading?: string;
}

const { locale, series, heading } = Astro.props;
const t = useTranslations(locale);

/** "8 parts · ~1h 4min · Beginner" — parts always, then total time and level when known. */
function metaOf(s: SeriesWithCount): string {
  const parts = [`${s.count} ${t('blog.parts')}`];
  if (s.totalMinutes > 0) {
    const h = Math.floor(s.totalMinutes / 60);
    const m = s.totalMinutes % 60;
    parts.push(h > 0 ? `~${h}h${m ? ` ${m}min` : ''}` : `${s.totalMinutes} ${t('blog.minRead')}`);
  }
  if (s.data.level) parts.push(t(`blog.difficulty.${s.data.level}` as UIKey));
  return parts.join(' · ');
}
---

{
  series.length > 0 && (
    <section aria-labelledby="series-spotlight" class="mt-10">
      <h2
        id="series-spotlight"
        class="text-muted-foreground text-xs font-semibold tracking-wide uppercase"
      >
        {heading ?? t('blog.series')}
      </h2>
      <ul class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {series.map((s) => (
          <li>
            <SeriesCard href={s.href} label={s.data.label} meta={metaOf(s)} slug={s.slug} />
          </li>
        ))}
      </ul>
    </section>
  )
}
