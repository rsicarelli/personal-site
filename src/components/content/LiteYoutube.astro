---
/**
 * Lightweight YouTube facade (#34) — renders the poster image + a play button, and only loads the
 * real (cookieless) iframe on click, so a talk page with an embed stays fast and ships no third-
 * party JS until the visitor opts in. This is a minimal page-owned STUB; swap it for Epic 5's
 * `lite-youtube` component when that lands (same intent, shared design-system styling).
 */
interface Props {
  /** A YouTube watch / share / embed URL. */
  url: string;
  title?: string;
}

const { url, title = 'Play video' } = Astro.props;

function youtubeId(raw: string): string | null {
  try {
    const u = new URL(raw);
    if (u.hostname === 'youtu.be') return u.pathname.slice(1) || null;
    if (u.searchParams.get('v')) return u.searchParams.get('v');
    const embed = u.pathname.match(/\/embed\/([^/?]+)/);
    return embed ? embed[1] : null;
  } catch {
    return null;
  }
}

const id = youtubeId(url);
const poster = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : null;
const embed = id ? `https://www.youtube-nocookie.com/embed/${id}?autoplay=1` : null;
---

{
  id && (
    <div class="border-border bg-muted relative aspect-video w-full overflow-hidden rounded-lg border">
      <button
        type="button"
        class="lite-yt group absolute inset-0 flex items-center justify-center"
        data-embed={embed}
        aria-label={title}
      >
        <img
          src={poster}
          alt=""
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <span class="bg-primary text-primary-foreground relative z-10 flex h-16 w-16 items-center justify-center rounded-full shadow-lg transition group-hover:scale-105">
          <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-7 w-7" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    </div>
  )
}

<script is:inline>
  document.querySelectorAll('button.lite-yt').forEach((btn) => {
    btn.addEventListener(
      'click',
      () => {
        const src = btn.getAttribute('data-embed');
        if (!src || !btn.parentElement) return;
        const iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.title = btn.getAttribute('aria-label') || 'YouTube video';
        iframe.loading = 'lazy';
        iframe.allow =
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.className = 'absolute inset-0 h-full w-full';
        btn.parentElement.replaceChildren(iframe);
      },
      { once: true },
    );
  });
</script>
