---
/**
 * PostCard (#231 C1, restyled for the title-banner cover direction) — one editorial list item shared
 * by the blog hub, tag archives and topic pages. The cover is now a full-width `CoverBanner` with the
 * post title meshed IN (topic tag top-right, series/part eyebrow, scrim for readability), and the
 * supporting meta (date · reading time · difficulty), the answer-first `summary`, and up to two tags
 * sit below it. The title link lives inside the banner, so there's no duplicate title and the whole
 * banner is one click target. Works at both sizes — taller banner on mobile, wider on desktop.
 *
 * Reading time is computed build-time via `readingTimeOf` (no render()).
 */
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import type { UIKey } from '@/i18n/ui';
import { slugifyTag, readingTimeOf } from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';
import CoverBanner from '@/components/content/CoverBanner.astro';

interface Props {
  locale: Locale;
  slug: string;
  entry: CollectionEntry<'blog'>;
  /** Resolved series label when the post belongs to a series (the caller holds the slug→label map). */
  seriesLabel?: string;
  /** Tag slugs with an archive page in BOTH locales — only these render as links (rest are plain). */
  tagPages: Set<string>;
  /** Reserved for callers (above-the-fold hint); the generated banner needs no eager fetch. */
  eager?: boolean;
}

const { locale, slug, entry, seriesLabel, tagPages } = Astro.props;
const t = useTranslations(locale);
const d = entry.data;
const href = `/${locale}/blog/${slug}`;
const minutes = readingTimeOf(entry);
const lede = d.summary ?? d.description;
const difficultyLabel = d.difficulty ? t(`blog.difficulty.${d.difficulty}` as UIKey) : undefined;
const topicLabel = t(`blog.topic.${d.topic}` as UIKey);
const eyebrow = seriesLabel
  ? `${seriesLabel}${d.seriesOrder != null ? ` · ${t('blog.part')} ${d.seriesOrder}` : ''}`
  : undefined;
const shownTags = d.tags.slice(0, 2);
---

<article class="border-border border-b pb-10 last:border-0">
  <CoverBanner
    seed={slug}
    topic={d.topic}
    series={d.series}
    part={d.seriesOrder}
    title={d.title}
    href={href}
    eyebrow={eyebrow}
    topicLabel={topicLabel}
    as="h3"
    headingClass="text-lg sm:text-xl"
    class="border-border rounded-lg border"
  />

  <p
    class="text-muted-foreground mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs"
  >
    <time datetime={isoDate(d.pubDate)}>{formatDate(d.pubDate, locale)}</time>
    <span aria-hidden="true">·</span>
    <span>{minutes} {t('blog.minRead')}</span>
    {
      difficultyLabel && (
        <>
          <span aria-hidden="true">·</span>
          <span>{difficultyLabel}</span>
        </>
      )
    }
  </p>

  <p class="text-muted-foreground mt-2 max-w-prose">{lede}</p>

  {
    shownTags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2 text-xs">
        {shownTags.map((tag) =>
          tagPages.has(slugifyTag(tag)) ? (
            <li>
              <a
                href={`/${locale}/blog/tags/${slugifyTag(tag)}`}
                class="border-border text-muted-foreground hover:text-foreground relative z-10 rounded-full border px-2 py-0.5 transition-colors"
              >
                {tag}
              </a>
            </li>
          ) : (
            <li class="text-muted-foreground border-border rounded-full border px-2 py-0.5">
              {tag}
            </li>
          ),
        )}
      </ul>
    )
  }
</article>
