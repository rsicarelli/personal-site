---
/**
 * PostCard (#231 C1) — the one editorial list row shared by the blog hub, tag archives and the
 * upcoming topic pages. A text-forward row (single-column list, not a grid) with: an answer-first
 * lede (`summary`, falling back to `description`), a metadata line (date · reading time · difficulty
 * · series/part badge), the title, and up to two tags. An optional 2:1 cover sits beside the text on
 * `sm+`; when a post has none, a deterministic no-cover block carries the topic label — no network,
 * fixed aspect ratio, so the row never shifts (CLS).
 *
 * Covers are plain `<img>` (remote dev.to CDN today, R2 later) with explicit width/height; the first
 * card on a page passes `eager` for a high-priority above-the-fold fetch. Reading time is computed
 * build-time via `readingTimeOf` (no render()).
 */
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import type { UIKey } from '@/i18n/ui';
import { slugifyTag, readingTimeOf } from '@/lib/content';
import { formatDate, isoDate } from '@/lib/datetime';

interface Props {
  locale: Locale;
  slug: string;
  entry: CollectionEntry<'blog'>;
  /** Resolved series label when the post belongs to a series (the caller holds the slug→label map). */
  seriesLabel?: string;
  /** Tag slugs with an archive page in BOTH locales — only these render as links (rest are plain). */
  tagPages: Set<string>;
  /** Above-the-fold hint: eager + high-priority cover fetch for the first/featured card. */
  eager?: boolean;
}

const { locale, slug, entry, seriesLabel, tagPages, eager = false } = Astro.props;
const t = useTranslations(locale);
const d = entry.data;
const href = `/${locale}/blog/${slug}`;
const minutes = readingTimeOf(entry);
const lede = d.summary ?? d.description;
const cover = d.cover?.src ?? d.coverUrl;
const coverW = d.cover?.width ?? 320;
const coverH = d.cover?.height ?? 160;
const difficultyLabel = d.difficulty ? t(`blog.difficulty.${d.difficulty}` as UIKey) : undefined;
const topicLabel = t(`blog.topic.${d.topic}` as UIKey);
const shownTags = d.tags.slice(0, 2);
---

<article
  class="border-border flex flex-col gap-4 border-b pb-10 last:border-0 sm:flex-row-reverse sm:items-start sm:gap-6"
>
  {
    /* Cover (or deterministic topic fallback) — fixed 2:1 box so there's no layout shift. Decorative:
      it duplicates the title link, so it's hidden from the a11y tree and out of the tab order. */
  }
  <a href={href} class="block w-full shrink-0 sm:w-52" tabindex="-1" aria-hidden="true">
    {
      cover ? (
        <img
          src={cover}
          width={coverW}
          height={coverH}
          alt=""
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
          {...(eager ? { fetchpriority: 'high' } : {})}
          class="border-border aspect-[2/1] w-full rounded-md border object-cover"
        />
      ) : (
        <div class="border-border bg-secondary text-muted-foreground flex aspect-[2/1] w-full items-center justify-center rounded-md border px-3 text-center font-mono text-xs">
          {topicLabel}
        </div>
      )
    }
  </a>

  <div class="min-w-0 flex-1">
    <p class="text-muted-foreground flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs">
      <time datetime={isoDate(d.pubDate)}>{formatDate(d.pubDate, locale)}</time>
      <span aria-hidden="true">·</span>
      <span>{minutes} {t('blog.minRead')}</span>
      {
        difficultyLabel && (
          <>
            <span aria-hidden="true">·</span>
            <span>{difficultyLabel}</span>
          </>
        )
      }
      {
        seriesLabel && (
          <span class="bg-secondary text-secondary-foreground rounded-md px-1.5 py-0.5">
            {seriesLabel}
            {d.seriesOrder != null && ` · ${t('blog.part')} ${d.seriesOrder}`}
          </span>
        )
      }
    </p>
    <h3 class="mt-2 text-xl font-semibold tracking-tight">
      <a href={href} class="hover:text-primary transition-colors">{d.title}</a>
    </h3>
    <p class="text-muted-foreground mt-2 max-w-prose">{lede}</p>
    {
      shownTags.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2 text-xs">
          {shownTags.map((tag) =>
            tagPages.has(slugifyTag(tag)) ? (
              <li>
                <a
                  href={`/${locale}/blog/tags/${slugifyTag(tag)}`}
                  class="border-border text-muted-foreground hover:text-foreground rounded-full border px-2 py-0.5 transition-colors"
                >
                  {tag}
                </a>
              </li>
            ) : (
              <li class="text-muted-foreground border-border rounded-full border px-2 py-0.5">
                {tag}
              </li>
            ),
          )}
        </ul>
      )
    }
  </div>
</article>
