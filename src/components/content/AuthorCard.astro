---
/**
 * AuthorCard — the "about the author" relationship hook below a post. Reuses the same sources as the
 * /about page: the portrait asset, `SITE.name`, and the CV collection (`headline` as the one-line bio
 * + `profiles` for follow links). Zero-JS; semantic tokens only.
 */
import Image from '@/components/ui/Image.astro';
import portrait from '@/assets/rodrigo-sicarelli.jpg';
import { SITE, type Locale } from '@/config/site';
import { useTranslations } from '@/i18n/utils';
import { getLocalizedEntry } from '@/lib/content';

interface Props {
  locale: Locale;
  class?: string;
}
const { locale, class: className } = Astro.props;
const t = useTranslations(locale);

const cv = (await getLocalizedEntry('cv', locale, 'cv'))?.entry;
const headline = cv?.data.headline ?? '';
const profiles = cv?.data.profiles ?? [];
---

<aside
  class:list={[
    'border-border bg-card flex flex-col gap-4 rounded-lg border p-5 sm:flex-row sm:items-center',
    className,
  ]}
>
  <Image
    src={portrait}
    alt={SITE.name}
    widths={[96, 192]}
    sizes="96px"
    class="border-border size-20 shrink-0 rounded-full border object-cover"
  />
  <div class="min-w-0">
    <p class="text-muted-foreground text-xs font-semibold tracking-wide uppercase">
      {t('blog.aboutAuthor')}
    </p>
    <p class="text-foreground mt-1 font-semibold">{SITE.name}</p>
    {headline && <p class="text-muted-foreground mt-0.5 text-sm text-pretty">{headline}</p>}
    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      <a
        href={`/${locale}/about`}
        class="text-primary font-medium underline-offset-4 hover:underline"
      >
        {t('blog.moreAbout')} →
      </a>
      {
        profiles.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            {p.network}
          </a>
        ))
      }
    </div>
  </div>
</aside>
