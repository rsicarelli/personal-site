---
/**
 * SeriesCard (#31, enriched in #231 C3) — one series in the blog spotlight grid. A linked `Card` with
 * a generated, theme-aware `<Cover>` (seeded by the series slug), the series label, and a metadata
 * line (parts · total reading time · level) composed by the caller. The whole card is the link, so
 * the cover is decorative (no `label`).
 */
import Card from '@/components/ui/Card.astro';
import Cover from '@/components/content/Cover.astro';

interface Props {
  href: string;
  label: string;
  /** Preformatted, already-localized line: e.g. "8 parts · ~1h 4min · Beginner". */
  meta: string;
  /** Series slug — seeds the generated cover art. */
  slug: string;
}

const { href, label, meta, slug } = Astro.props;
---

<Card href={href} class="flex flex-col gap-3">
  <Cover seed={slug} series={slug} class="border-border rounded-md border" />
  <div>
    <h3 class="font-semibold tracking-tight">{label}</h3>
    <p class="text-muted-foreground mt-1 font-mono text-xs">{meta}</p>
  </div>
</Card>
