---
/**
 * SeriesCard (#31, restyled for the title-banner direction) — one series in the blog spotlight grid:
 * a linked `Card` whose cover is a `CoverBanner` with the series label meshed in, and the metadata
 * line (parts · total reading time · level) below. The whole `Card` is the link, so the banner carries
 * no nested anchor (label is plain text inside it).
 */
import Card from '@/components/ui/Card.astro';
import CoverBanner from '@/components/content/CoverBanner.astro';

interface Props {
  href: string;
  label: string;
  /** Preformatted, already-localized line: e.g. "8 parts · ~1h 4min · Beginner". */
  meta: string;
  /** Series slug — seeds the generated cover art. */
  slug: string;
}

const { href, label, meta, slug } = Astro.props;
---

<Card href={href} class="flex flex-col gap-3">
  <CoverBanner
    seed={slug}
    series={slug}
    title={label}
    as="h3"
    headingClass="text-base"
    class="border-border rounded-md border"
  />
  <p class="text-muted-foreground font-mono text-xs">{meta}</p>
</Card>
