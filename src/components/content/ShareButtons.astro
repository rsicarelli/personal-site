---
/**
 * ShareButtons (#194) — trackerless, cookieless social sharing for a blog post.
 *
 * Baseline is zero-JS: the X / Bluesky / LinkedIn / email links are plain server-rendered `<a>`s
 * the browser opens directly (no SDK, no counts, nothing runs until a click). Two buttons are
 * progressive enhancements, `hidden` until the inline script confirms support: "Copy link"
 * (Clipboard API) and the native OS "Share…" sheet (`navigator.share`) — which is how Mastodon /
 * fediverse / WhatsApp etc. are covered. No cookies, no localStorage.
 *
 * The inline `<script>` reads the URL/title and labels from `data-*` attributes only (no Astro
 * interpolation), so its emitted bytes are identical on every page → a single stable CSP hash
 * (allow-listed in `public/_headers`, guarded by tests/security/csp-hashes.test.ts).
 */
import { useTranslations } from '@/i18n/utils';
import type { Locale } from '@/config/site';
import { shareTargets } from '@/lib/share';

interface Props {
  /** Absolute canonical post URL (from `canonicalUrl()`). */
  url: string;
  /** Post title. */
  title: string;
  locale: Locale;
  class?: string;
}

const { url, title, locale, class: className } = Astro.props;
const t = useTranslations(locale);
const targets = shareTargets(url, title);

const pill =
  'inline-flex items-center gap-1.5 hover:text-foreground focus-visible:text-foreground transition-colors';

// Inline brand/UI glyphs (zero-JS, no icon dependency — same approach as ArticleMeta).
const ICON: Record<string, string> = {
  twitter:
    'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  bluesky:
    'M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z',
  linkedin:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  email:
    'M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Zm21-1.762V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z',
  copy: 'M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z',
  native:
    'M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z',
};
---

<nav
  data-share
  data-share-url={url}
  data-share-title={title}
  aria-label={t('blog.share.label')}
  class:list={[
    'border-border bg-card text-muted-foreground flex flex-wrap items-center gap-x-4 gap-y-2 rounded-lg border px-4 py-3 text-sm',
    className,
  ]}
>
  <span class="font-medium" aria-hidden="true">{t('blog.share.label')}</span>

  {
    targets.map((target) => (
      <a
        href={target.href}
        aria-label={t(target.labelKey)}
        class={pill}
        {...(target.id === 'email' ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
      >
        <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
          <path d={ICON[target.id]} />
        </svg>
      </a>
    ))
  }

  <button type="button" data-share-copy hidden class={pill} aria-label={t('blog.share.copy')}>
    <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
      <path d={ICON.copy}></path>
    </svg>
    <span
      data-share-copy-label
      data-idle={t('blog.share.copy')}
      data-copied={t('blog.share.copied')}
      aria-live="polite"
    >
      {t('blog.share.copy')}
    </span>
  </button>

  <button type="button" data-share-native hidden class={pill}>
    <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true">
      <path d={ICON.native}></path>
    </svg>
    {t('blog.share.native')}
  </button>
</nav>

<script>
  // Progressive enhancement for ShareButtons (#194). Bound on `astro:page-load` (fires on first
  // load AND after each View Transition swap) — same pattern as the About print button. Reveals the
  // Copy / native-share buttons only when the API exists; reads everything from `data-*` so the
  // emitted bytes (and thus the CSP hash) are identical on every page.
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('[data-share]').forEach((root) => {
      const url = root.getAttribute('data-share-url') || location.href;
      const title = root.getAttribute('data-share-title') || document.title;

      const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');
      if (copyBtn && navigator.clipboard) {
        copyBtn.hidden = false;
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(url);
          } catch {
            return;
          }
          const label = copyBtn.querySelector<HTMLElement>('[data-share-copy-label]');
          if (!label) return;
          const idle = label.getAttribute('data-idle') ?? '';
          label.textContent = label.getAttribute('data-copied') ?? idle;
          setTimeout(() => {
            label.textContent = idle;
          }, 2000);
        });
      }

      const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]');
      if (nativeBtn && typeof navigator.share === 'function') {
        nativeBtn.hidden = false;
        nativeBtn.addEventListener('click', () => {
          navigator.share({ title, url }).catch(() => {});
        });
      }
    });
  });
</script>
